---
import BaseLayout from "@/layouts/BaseLayout.astro";
import {config} from "@/lib/config/client.ts";

const {credits} = config;
const currentDate = new Date().toLocaleDateString();
---

<BaseLayout title="Credits | TRESR">
  <div class="min-h-screen pt-20 pb-10">
    <div class="container mx-auto max-w-2xl px-4 text-center">
      <h1
        class="text-primary font-display mb-12 text-5xl font-black tracking-widest drop-shadow-[0_0_10px_rgba(var(--primary),0.8)]"
      >
        CREDITS
      </h1>

      <!-- Ron Jay Briefing -->
      <div class="mb-12 w-full">
        <div class="chat chat-start w-full">
          <div
            class="chat-image avatar translate-y-3 items-end sm:translate-y-4"
          >
            <div
              class="mask mask-squircle w-16 shadow-lg drop-shadow-[0_0_5px_rgba(var(--primary),0.3)] sm:w-20"
            >
              <img
                src="/assets/images/ron_jay_speech_bubble.webp"
                alt="Ron Jay"
              />
            </div>
          </div>
          <div class="chat-header mb-1 font-bold opacity-80">
            Ron Jay
            <span class="text-xs font-normal opacity-50">Credits</span>
          </div>
          <div
            class="chat-bubble chat-bubble-primary text-left text-sm whitespace-pre-line sm:text-base"
          >
            {credits?.description}
          </div>
        </div>
      </div>

      <div class="flex flex-col gap-16">
        <!-- Team Section -->
        <section>
          <h2
            class="text-secondary mb-6 font-mono text-2xl tracking-widest uppercase"
          >
            The Crew
          </h2>
          <div class="grid gap-4">
            {
              credits?.coders?.map((c) => (
                <div class="card bg-base-200/50 border-primary/20 border">
                  <div class="card-body gap-1 p-4">
                    <div class="card-title text-base">{c.name}</div>
                    <div class="text-sm opacity-70">{c.role}</div>
                    {c.description && (
                      <div class="mt-1 text-xs italic">{c.description}</div>
                    )}
                  </div>
                </div>
              ))
            }
          </div>
        </section>

        <!-- Tech Stack -->
        <section>
          <h2
            class="text-secondary mb-6 font-mono text-2xl tracking-widest uppercase"
          >
            Powered By
          </h2>
          <div class="flex flex-wrap justify-center gap-3">
            {
              credits?.components?.map((component) => (
                <span class="badge badge-lg badge-outline border-primary text-primary whitespace-nowrap">
                  {component.name}
                </span>
              ))
            }
          </div>
        </section>

        <!-- Assets -->
        <section>
          <h2
            class="text-secondary mb-6 font-mono text-2xl tracking-widest uppercase"
          >
            Assets
          </h2>
          <div class="grid gap-4">
            {
              credits?.assets?.map((asset) => (
                <div class="card bg-base-200/50 border-primary/20 border">
                  <div class="card-body p-4">
                    <div class="font-mono text-sm opacity-70">
                      {asset.subtype
                        ? `${asset.type} (${asset.subtype}): ${asset.provider}`
                        : `${asset.type}: ${asset.provider}`}
                    </div>
                  </div>
                </div>
              ))
            }
          </div>
        </section>
      </div>

      <div class="mt-16 font-mono text-xs opacity-50">
        Generated on {currentDate}
      </div>

      <div class="mt-4">
        <a
          href="/"
          class="btn btn-outline btn-primary font-mono tracking-widest"
        >
          RETURN HOME
        </a>
      </div>
    </div>
  </div>
</BaseLayout>
