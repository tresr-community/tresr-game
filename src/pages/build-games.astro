---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="Build Games | TRESR">
  <div class="min-h-screen pt-20 pb-10">
    <div class="container mx-auto max-w-3xl px-4 text-center">
      <h1
        class="text-primary font-display mb-4 text-5xl font-black tracking-widest drop-shadow-[0_0_10px_rgba(var(--primary),0.8)]"
      >
        BUILD GAMES 2026
      </h1>
      <p class="mb-12 font-mono text-sm opacity-60">
        Avalanche Build Games &middot; $1,000,000 Prize Pool &middot; 6 Weeks
      </p>

      <!-- Stages — DaisyUI steps (vertical) -->
      <ul class="steps steps-vertical w-full text-left">
        <!-- Stage 1: Idea — SUBMITTED -->
        <li class="step step-primary">
          <div class="ml-4 w-full pb-10">
            <div class="mb-2 flex flex-wrap items-center gap-2">
              <span class="badge badge-primary font-mono">STAGE 1</span>
              <span class="badge badge-success badge-outline font-mono"
                >SUBMITTED</span
              >
            </div>
            <h2
              class="text-secondary mb-1 font-mono text-2xl tracking-widest uppercase"
            >
              Idea
            </h2>
            <p class="mb-1 font-mono text-xs opacity-50">
              Deadline: February 25, 2026
            </p>
            <p class="mb-6 text-sm opacity-70">
              1-minute video pitch explaining the project idea, target problem,
              solution approach, and value proposition.
            </p>
            <div
              class="card bg-base-200/50 border-primary/20 overflow-hidden border"
            >
              <figure class="px-4 pt-4">
                <video
                  src="/assets/videos/stage-1.webm"
                  controls
                  playsinline
                  preload="metadata"
                  class="w-full rounded-lg"
                >
                  Your browser does not support WebM video.
                </video>
              </figure>
              <div class="card-body items-center text-center">
                <p class="font-mono text-xs opacity-50">Stage 1 Pitch</p>
                <a
                  href="https://youtu.be/i383N6NwAbw"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="btn btn-outline btn-error btn-sm mt-2 font-mono tracking-wider"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 24 24"
                    fill="currentColor"
                    class="size-[1.2em]"
                  >
                    <path
                      d="M23.5 6.2a3 3 0 0 0-2.1-2.1C19.5 3.5 12 3.5 12 3.5s-7.5 0-9.4.6A3 3 0 0 0 .5 6.2 31.5 31.5 0 0 0 0 12a31.5 31.5 0 0 0 .5 5.8 3 3 0 0 0 2.1 2.1c1.9.6 9.4.6 9.4.6s7.5 0 9.4-.6a3 3 0 0 0 2.1-2.1A31.5 31.5 0 0 0 24 12a31.5 31.5 0 0 0-.5-5.8ZM9.6 15.6V8.4l6.3 3.6-6.3 3.6Z"
                    ></path>
                  </svg>
                  Watch on YouTube
                </a>
              </div>
            </div>
          </div>
        </li>

        <!-- Stage 2: MVP — PENDING -->
        <li class="step opacity-40">
          <div class="ml-4 w-full pb-10">
            <div class="mb-2 flex flex-wrap items-center gap-2">
              <span class="badge badge-neutral font-mono">STAGE 2</span>
              <span class="badge badge-ghost badge-outline font-mono"
                >PENDING</span
              >
            </div>
            <h2
              class="text-secondary mb-1 font-mono text-2xl tracking-widest uppercase"
            >
              MVP
            </h2>
            <p class="mb-1 font-mono text-xs opacity-50">
              Deadline: March 9, 2026
            </p>
            <p class="text-sm opacity-70">
              Functional prototype, GitHub repository, technical documentation,
              and product walkthrough video.
            </p>
          </div>
        </li>

        <!-- Stage 3: GTM & Vision — PENDING -->
        <li class="step opacity-40">
          <div class="ml-4 w-full pb-10">
            <div class="mb-2 flex flex-wrap items-center gap-2">
              <span class="badge badge-neutral font-mono">STAGE 3</span>
              <span class="badge badge-ghost badge-outline font-mono"
                >PENDING</span
              >
            </div>
            <h2
              class="text-secondary mb-1 font-mono text-2xl tracking-widest uppercase"
            >
              GTM &amp; Vision
            </h2>
            <p class="mb-1 font-mono text-xs opacity-50">
              Deadline: March 19, 2026
            </p>
            <p class="text-sm opacity-70">
              Go-to-market plan, growth strategy, user personas, competitive
              analysis, and long-term vision.
            </p>
          </div>
        </li>

        <!-- Stage 4: Finals — PENDING -->
        <li class="step opacity-40">
          <div class="ml-4 w-full pb-6">
            <div class="mb-2 flex flex-wrap items-center gap-2">
              <span class="badge badge-neutral font-mono">STAGE 4</span>
              <span class="badge badge-ghost badge-outline font-mono"
                >PENDING</span
              >
            </div>
            <h2
              class="text-secondary mb-1 font-mono text-2xl tracking-widest uppercase"
            >
              Finals
            </h2>
            <p class="mb-1 font-mono text-xs opacity-50">
              Deadline: March 27, 2026
            </p>
            <p class="text-sm opacity-70">
              Final pitch deck, live product demo, complete documentation, and
              Q&amp;A with judges.
            </p>
          </div>
        </li>
      </ul>

      <div class="mt-16 font-mono text-xs opacity-50">
        Avalanche Build Games 2026 &middot; <a
          href="https://build.avax.network/build-games"
          target="_blank"
          class="link link-primary">build.avax.network</a
        >
      </div>

      <div class="mt-4">
        <a
          href="/"
          class="btn btn-outline btn-primary font-mono tracking-widest"
        >
          RETURN TO BASE
        </a>
      </div>
    </div>
  </div>
</BaseLayout>
