---
// VaultBalance.astro — Vault prize pool with difficulty indicator, cooldown timer, and win toast
---

<div
  id="vault-balance-card"
  class="stats bg-base-200/50 border-warning/30 hidden border shadow"
>
  <div class="stat place-items-center">
    <div class="stat-title font-mono text-xs whitespace-nowrap">
      VAULT PRIZE POOL
    </div>
    <span id="vault-difficulty" class="badge badge-sm badge-ghost hidden"
    ></span>
    <div id="vault-balance" class="stat-value text-warning text-3xl">
      <span class="loading loading-dots loading-sm"></span>
    </div>
    <div class="stat-desc flex items-center gap-2 font-mono">
      <span id="vault-ticker">$TRESR</span>
      <span id="vault-cooldown" class="hidden text-xs opacity-70"></span>
    </div>
  </div>
</div>

<!-- FOMO Win Toast (fixed top) -->
<div
  id="win-toast"
  class="toast toast-top toast-center z-50 hidden transition-all duration-500"
>
  <div
    class="alert alert-success border-success/50 bg-success/20 shadow-lg backdrop-blur"
  >
    <span id="win-toast-text" class="font-mono text-sm"></span>
  </div>
</div>

<script>
  import {getVaultTresrBalance} from "@/lib/wallet/balance";
  import {
    getEnvironmentKey,
    isVaultDeployed,
    shortenAddress,
  } from "@/lib/wallet/avalanche";
  import {getReadClient} from "@/lib/wallet/tx";
  import {getClaimCooldownStatus} from "@/lib/wallet/avalanche";
  import {
    subscribeToConnection,
    getConnectedAddress,
  } from "@/lib/wallet/connection";
  import {config} from "@/lib/config/client";
  import {log} from "@/lib/utils/log";
  import {subscribeToAuth} from "@/lib/auth";
  import {
    getVaultTier,
    formatCooldown,
    formatVaultDisplay,
  } from "@/lib/wallet/vault-status";
  import {VaultAbi} from "@/lib/wallet/VaultAbi";

  const COMPONENT_NAME = "VaultBalance";
  const REFRESH_INTERVAL_MS = 60_000;
  const COOLDOWN_TICK_MS = 1_000;
  const MAX_CONSECUTIVE_ERRORS = 3;
  const WIN_TOAST_DURATION_MS = 8_000;

  const cardEl = document.getElementById("vault-balance-card");
  const balanceEl = document.getElementById("vault-balance");
  const tickerEl = document.getElementById("vault-ticker");
  const difficultyEl = document.getElementById("vault-difficulty");
  const cooldownEl = document.getElementById("vault-cooldown");
  const winToastEl = document.getElementById("win-toast");
  const winToastTextEl = document.getElementById("win-toast-text");

  // Set ticker from config
  const env = getEnvironmentKey();
  const ticker = config.blockchain.avalanche[env].token_ticker;
  if (tickerEl) tickerEl.textContent = `$${ticker}`;

  let interval: ReturnType<typeof setInterval> | null = null;
  let cooldownInterval: ReturnType<typeof setInterval> | null = null;
  let walletConnected = false;
  let isAuthenticatedNonGuest = false;
  let consecutiveErrors = 0;
  let disposed = false;

  let cooldownRemaining = 0;
  let unwatchClaim: (() => void) | null = null;
  let winToastTimeout: ReturnType<typeof setTimeout> | null = null;

  // -----------------------------------------------------------------------
  // Difficulty badge
  // -----------------------------------------------------------------------
  function updateDifficultyBadge(balanceWei: bigint) {
    if (!difficultyEl) return;
    const tier = getVaultTier(balanceWei);

    difficultyEl.textContent = `${tier.emoji} ${tier.label}`;
    difficultyEl.className = `badge badge-sm ${tier.colorClass}`;
    difficultyEl.classList.remove("hidden");

    // Dispatch event for homepage START button lock
    document.dispatchEvent(
      new CustomEvent("tresr:vault-status", {
        detail: {
          tier: tier.tier,
          locked: tier.tier === "locked",
          balance: balanceWei,
        },
      })
    );
  }

  // -----------------------------------------------------------------------
  // Cooldown timer
  // -----------------------------------------------------------------------
  async function fetchCooldown() {
    if (disposed || !walletConnected) return;
    try {
      const address = getConnectedAddress();
      if (!address) return;
      const status = await getClaimCooldownStatus(address);
      cooldownRemaining = status.remainingSeconds;
      updateCooldownDisplay();
      startCooldownTick();
    } catch {
      // Silently fail — cooldown is a nice-to-have
    }
  }

  function updateCooldownDisplay() {
    if (!cooldownEl) return;
    if (cooldownRemaining <= 0) {
      cooldownEl.textContent = "✅ READY";
      cooldownEl.classList.remove("hidden", "text-error");
      cooldownEl.classList.add("text-success");
    } else {
      cooldownEl.textContent = `⏱️ ${formatCooldown(cooldownRemaining)}`;
      cooldownEl.classList.remove("hidden", "text-success");
      cooldownEl.classList.add("text-error");
    }
  }

  function startCooldownTick() {
    stopCooldownTick();
    if (cooldownRemaining <= 0) return;
    cooldownInterval = setInterval(() => {
      cooldownRemaining = Math.max(0, cooldownRemaining - 1);
      updateCooldownDisplay();
      if (cooldownRemaining <= 0) stopCooldownTick();
    }, COOLDOWN_TICK_MS);
  }

  function stopCooldownTick() {
    if (cooldownInterval) {
      clearInterval(cooldownInterval);
      cooldownInterval = null;
    }
  }

  // -----------------------------------------------------------------------
  // Win toast (FOMO) + confetti 🎉
  // -----------------------------------------------------------------------

  function showWinToast(user: string, amountWei: bigint) {
    if (disposed) return;
    if (!winToastEl || !winToastTextEl) return;

    const amountDisplay = formatVaultDisplay(amountWei);
    const shortAddr = shortenAddress(user);
    winToastTextEl.textContent = `🏆 ${shortAddr} just won ${amountDisplay} $${ticker}!`;

    winToastEl.classList.remove("hidden");
    document.dispatchEvent(new CustomEvent("tresr:confetti"));

    // Auto-hide
    if (winToastTimeout) clearTimeout(winToastTimeout);
    winToastTimeout = setTimeout(() => {
      winToastEl.classList.add("hidden");
    }, WIN_TOAST_DURATION_MS);

    // Refresh balance immediately on win
    updateBalance();
  }

  async function startWatchingClaims() {
    if (unwatchClaim || disposed) return;
    if (!isVaultDeployed(config)) return;

    try {
      const publicClient = getReadClient();
      const vaultAddress = config.blockchain.avalanche[env]
        .vault_contract as `0x${string}`;

      unwatchClaim = publicClient.watchContractEvent({
        address: vaultAddress,
        abi: VaultAbi,
        eventName: "Claim",
        onLogs: (logs) => {
          for (const l of logs) {
            const args = l.args as {user?: string; amount?: bigint} | undefined;
            if (args?.user && args?.amount) {
              log.info(
                COMPONENT_NAME,
                `Claim detected: ${args.user} won ${args.amount}`
              );
              showWinToast(args.user, args.amount);
            }
          }
        },
      });
      log.info(COMPONENT_NAME, "Watching for Claim events");
    } catch (err) {
      log.error(
        COMPONENT_NAME,
        "Failed to watch Claim events:",
        err instanceof Error ? err.message : String(err)
      );
    }
  }

  function stopWatchingClaims() {
    if (unwatchClaim) {
      unwatchClaim();
      unwatchClaim = null;
    }
  }

  // -----------------------------------------------------------------------
  // Balance polling (existing logic, enhanced)
  // -----------------------------------------------------------------------
  async function updateBalance() {
    if (!balanceEl || disposed) return;

    try {
      const balance = await getVaultTresrBalance();
      if (disposed) return;

      balanceEl.textContent = formatVaultDisplay(balance);
      updateDifficultyBadge(balance);
      consecutiveErrors = 0;
    } catch (err) {
      if (disposed) return;
      consecutiveErrors++;
      if (consecutiveErrors <= MAX_CONSECUTIVE_ERRORS) {
        log.error(
          COMPONENT_NAME,
          "Failed to fetch vault balance:",
          err instanceof Error ? err.message : String(err)
        );
      } else if (consecutiveErrors === MAX_CONSECUTIVE_ERRORS + 1) {
        log.info(
          COMPONENT_NAME,
          `Suppressing further vault balance errors (${consecutiveErrors} consecutive failures)`
        );
      }
      balanceEl.textContent = "--";
    }
  }

  function startPolling() {
    updateBalance();
    if (!interval) {
      interval = setInterval(updateBalance, REFRESH_INTERVAL_MS);
    }
    fetchCooldown();
    startWatchingClaims();
  }

  function stopPolling() {
    if (interval) {
      clearInterval(interval);
      interval = null;
    }
    stopCooldownTick();
    stopWatchingClaims();
  }

  function showPlaceholder() {
    if (balanceEl) balanceEl.textContent = "--";
    if (difficultyEl) difficultyEl.classList.add("hidden");
    if (cooldownEl) cooldownEl.classList.add("hidden");
  }

  /**
   * Re-evaluate whether we should be polling based on auth + wallet state.
   * Card is visible for any authenticated non-guest user.
   * RPC polling only runs when an Avalanche wallet is connected.
   */
  function evaluatePolling() {
    if (isAuthenticatedNonGuest) {
      if (cardEl) cardEl.classList.remove("hidden");
      if (walletConnected) {
        consecutiveErrors = 0;
        startPolling();
      } else {
        stopPolling();
        showPlaceholder();
      }
    } else {
      if (cardEl) cardEl.classList.add("hidden");
      stopPolling();
      if (balanceEl) {
        const spinner = document.createElement("span");
        spinner.className = "loading loading-dots loading-sm";
        balanceEl.replaceChildren(spinner);
      }
    }
  }

  // Defer wallet subscription until user is authenticated to avoid
  // initializing AppKit (and its COOP check) for guest users.
  let unsubWallet: (() => void) | null = null;

  const unsubAuth = subscribeToAuth((state) => {
    isAuthenticatedNonGuest = state.isAuthenticated && !state.isGuest;

    // Only subscribe to wallet connection when authenticated (lazy init)
    if (isAuthenticatedNonGuest && !unsubWallet) {
      unsubWallet = subscribeToConnection((connected) => {
        walletConnected = connected;
        evaluatePolling();
      });
    } else if (!isAuthenticatedNonGuest && unsubWallet) {
      unsubWallet();
      unsubWallet = null;
      walletConnected = false;
    }

    evaluatePolling();
  });

  // Refresh on page focus (only if polling is active)
  function handleVisibilityChange() {
    if (document.visibilityState === "visible" && interval) {
      updateBalance();
    }
  }
  document.addEventListener("visibilitychange", handleVisibilityChange);

  // Cleanup on navigation
  document.addEventListener(
    "astro:before-preparation",
    () => {
      disposed = true;
      stopPolling();
      unsubAuth();
      if (unsubWallet) unsubWallet();
      document.removeEventListener("visibilitychange", handleVisibilityChange);
      if (winToastTimeout) clearTimeout(winToastTimeout);
    },
    {once: true}
  );
</script>
