---
import {config} from "@/lib/config/client";

const gp = config.gameplay;
const playerHealth = gp.entities.player.health;
const bossHealth = gp.entities.boss.health;
const timerSeconds = gp.time_limit_seconds;
const timerMin = Math.floor(timerSeconds / 60)
  .toString()
  .padStart(2, "0");
const timerSec = (timerSeconds % 60).toString().padStart(2, "0");
---

<div
  class="hud-desktop:p-4 pointer-events-none absolute inset-0 flex flex-col justify-between p-2"
  style="padding-top: max(0.5rem, var(--safe-top)); padding-left: max(0.5rem, var(--safe-left)); padding-right: max(0.5rem, var(--safe-right)); padding-bottom: max(0.5rem, var(--safe-bottom));"
>
  <!-- Top Bar -->
  <div class="hud-desktop:gap-4 grid w-full grid-cols-3 items-start gap-1">
    <!-- Left: Stats -->
    <div class="flex justify-start">
      <div
        class="stats bg-base-300/80 border-primary/20 pointer-events-auto border shadow-lg backdrop-blur"
      >
        <div class="stat hud-desktop:p-2 hud-desktop:px-4 p-1 px-2">
          <div
            class="stat-title hud-desktop:text-[10px] text-center text-[8px] uppercase opacity-50"
          >
            <!-- Emoji on mobile (short viewport), text on desktop (tall viewport) -->
            <span class="hud-emoji">❤️</span>
            <span class="hud-label">HP</span>
          </div>
          <div
            id="hud-hp"
            class="stat-value text-error hud-desktop:text-xl text-center font-mono text-sm"
          >
            {playerHealth}
          </div>
        </div>
        <div
          class="stat border-primary/10 hud-desktop:p-2 hud-desktop:px-4 border-l p-1 px-2"
        >
          <div
            class="stat-title hud-desktop:text-[10px] text-center text-[8px] uppercase opacity-50"
          >
            <span class="hud-emoji">⭐</span>
            <span class="hud-label">Score</span>
          </div>
          <div
            id="hud-score"
            class="stat-value text-primary hud-desktop:text-xl text-center font-mono text-sm"
          >
            0
          </div>
        </div>
        <div
          class="stat border-primary/10 hud-desktop:p-2 hud-desktop:px-4 border-l p-1 px-2"
        >
          <div
            class="stat-title hud-desktop:text-[10px] text-center text-[8px] uppercase opacity-50"
          >
            <span class="hud-emoji">🔑</span>
            <span class="hud-label">Keys</span>
          </div>
          <div
            id="hud-keys"
            class="stat-value text-secondary hud-desktop:text-xl text-center font-mono text-sm"
          >
            0
          </div>
        </div>
        <div
          id="hud-lives-stat"
          class="stat border-primary/10 hud-desktop:p-2 hud-desktop:px-4 hidden border-l p-1 px-2"
        >
          <div
            class="stat-title hud-desktop:text-[10px] text-center text-[8px] uppercase opacity-50"
          >
            <span class="hud-emoji">🛡️</span>
            <span class="hud-label">Lives</span>
          </div>
          <div
            id="hud-lives"
            class="stat-value text-warning hud-desktop:text-xl font-mono text-sm"
          >
            1
          </div>
        </div>
        <!-- Super Charge Radial Ring -->
        <div
          class="stat border-primary/10 hud-desktop:p-2 hud-desktop:px-3 border-l p-1 px-2"
        >
          <div
            class="stat-title hud-desktop:text-[10px] text-center text-[8px] uppercase opacity-50"
          >
            <span class="hud-emoji">⚡</span>
            <span class="hud-label">Super</span>
          </div>
          <div class="flex items-center justify-center">
            <div
              id="hud-super-ring"
              class="radial-progress text-error transition-all duration-200"
              style="--value:0; --size:2.25rem; --thickness:3px;"
              role="progressbar"
            >
              <span id="hud-super-icon" class="text-xs select-none">⚡</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Center: Timer -->
    <div class="flex justify-center">
      <div
        class="stats bg-base-300/80 border-error/20 pointer-events-auto border shadow-lg backdrop-blur"
      >
        <div class="stat hud-desktop:p-2 hud-desktop:px-6 p-1 px-3">
          <div
            class="stat-title hud-desktop:text-[10px] text-center text-[8px] uppercase opacity-50"
          >
            <span class="hud-emoji">🕐</span>
            <span class="hud-label">System Clock</span>
          </div>
          <div
            id="hud-timer-wrapper"
            class="stat-value text-error hud-desktop:text-lg hud-tall:text-3xl flex items-center justify-center font-mono text-sm"
          >
            <span class="countdown">
              <span
                id="hud-timer-min"
                style={`--value:${timerMin}; --digits:2;`}
                aria-label={timerMin}></span>
            </span>
            :
            <span class="countdown">
              <span
                id="hud-timer-sec"
                style={`--value:${timerSec}; --digits:2;`}
                aria-label={timerSec}></span>
            </span>
          </div>
        </div>
      </div>
    </div>

    <!-- Right: Admin icon (visible only for admin principals). Security enforced by canister. -->
    <div class="flex justify-end">
      <a
        id="admin-icon-btn"
        href="/admin"
        class="btn btn-circle btn-ghost btn-sm pointer-events-auto hidden opacity-70 hover:opacity-100"
        title="Admin panel"
        aria-label="Admin panel">🛡️</a
      >
    </div>
  </div>

  <!-- Bottom HUD Area: 3-column grid with min-w-0 on sides to guarantee true centering -->
  <div class="grid w-full grid-cols-3 items-end">
    <div class="min-w-0"></div>

    <!-- Center: Pause Button + Phase Alerts -->
    <div
      class="hud-desktop:gap-2 hud-desktop:pb-4 flex flex-col items-center gap-1 pb-2"
    >
      <div
        id="hud-phase-alert"
        class="badge badge-primary hud-desktop:badge-lg hud-desktop:text-xs hidden text-[10px] font-bold tracking-widest uppercase"
      >
        BOSS INCOMING
      </div>
      <button
        id="btn-hud-pause"
        class="btn btn-circle btn-primary btn-sm hud-desktop:btn-md pointer-events-auto min-h-[48px] min-w-[48px] border-2 border-white/10 shadow-xl"
        title="Pause Mission (ESC)"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="currentColor"
        >
          <rect x="6" y="4" width="4" height="16"></rect>
          <rect x="14" y="4" width="4" height="16"></rect>
        </svg>
      </button>
    </div>

    <!-- Right: Boss HP Bar (only visible during boss phase) -->
    <div class="flex min-w-0 flex-col items-end justify-end gap-2">
      <div
        id="hud-boss-bar"
        class="bg-base-300/80 border-error/30 hud-desktop:w-40 hud-desktop:p-1.5 hud-tall:w-48 pointer-events-auto hidden w-28 rounded-lg border p-1 shadow-lg backdrop-blur"
      >
        <div class="flex items-center justify-between">
          <span class="text-error text-[9px] font-bold uppercase opacity-80"
            >BOSS</span
          >
          <span id="hud-boss-hp-text" class="text-error font-mono text-[10px]"
            >{bossHealth}/{bossHealth}</span
          >
        </div>
        <progress
          id="hud-boss-hp"
          class="progress progress-success mt-0.5 h-2 w-full"
          value="100"
          max="100"></progress>
      </div>
    </div>
  </div>
</div>

<script>
  import {gameActions, gameState} from "@/lib/game/state";
  import {config} from "@/lib/config/client";
  import {initSatellite} from "@junobuild/core";
  import {getErrors} from "@/declarations/satellite/satellite.api";

  // Show admin icon if the caller is an admin (canister confirms via get_errors).
  // initSatellite() must be called before any satellite API. It is idempotent,
  // so calling it here is safe even if game.astro already called it via initAuth().
  (async () => {
    try {
      await initSatellite();
      const result = await getErrors();
      if ("Ok" in result) {
        document.getElementById("admin-icon-btn")?.classList.remove("hidden");
      }
    } catch {
      // Not admin or not authenticated — icon stays hidden
    }
  })();

  const gp = config.gameplay;
  const thresholds = gp.health_bar.thresholds;
  const maxCharge = gp.entities.player.super.max_charge;

  const playerLives = gp.entities.player.lives;

  const elHp = document.getElementById("hud-hp");
  const elScore = document.getElementById("hud-score");
  const elKeys = document.getElementById("hud-keys");
  const elTimerWrapper = document.getElementById("hud-timer-wrapper");
  const elTimerMin = document.getElementById("hud-timer-min");
  const elTimerSec = document.getElementById("hud-timer-sec");
  const elPhase = document.getElementById("hud-phase-alert");
  const elLivesStat = document.getElementById("hud-lives-stat");
  const elLives = document.getElementById("hud-lives");
  const btnPause = document.getElementById("btn-hud-pause");

  // Only show lives counter when player has multiple lives
  if (playerLives > 1 && elLivesStat) {
    elLivesStat.classList.remove("hidden");
  }

  // Super charge radial ring
  const elSuperRing = document.getElementById("hud-super-ring");

  // Boss HP elements
  const elBossBar = document.getElementById("hud-boss-bar");
  const elBossHp = document.getElementById(
    "hud-boss-hp"
  ) as HTMLProgressElement;
  const elBossHpText = document.getElementById("hud-boss-hp-text");

  function handlePauseClick() {
    gameActions.togglePause();
  }
  btnPause?.addEventListener("click", handlePauseClick);

  const unsub = gameState.subscribe((state) => {
    if (elHp) elHp.innerText = state.hp.toString();
    if (elScore) elScore.innerText = state.score.toString();
    if (elKeys) elKeys.innerText = state.keys.toString();
    if (elLives) elLives.innerText = state.lives.toString();

    if (elTimerMin && elTimerSec) {
      const min = Math.floor(state.timer / 60)
        .toString()
        .padStart(2, "0");
      const sec = (state.timer % 60).toString().padStart(2, "0");
      elTimerMin.style.setProperty("--value", min);
      elTimerMin.setAttribute("aria-label", min);
      elTimerSec.style.setProperty("--value", sec);
      elTimerSec.setAttribute("aria-label", sec);

      // Flash timer during final 3 seconds
      if (elTimerWrapper) {
        if (state.timer <= 3 && state.timer > 0) {
          elTimerWrapper.classList.add(
            "animate-pulse",
            "text-warning",
            "scale-110"
          );
        } else {
          elTimerWrapper.classList.remove(
            "animate-pulse",
            "text-warning",
            "scale-110"
          );
        }
      }
    }

    // Super charge radial ring update
    if (elSuperRing) {
      const pct = state.superCharge / maxCharge;
      elSuperRing.style.setProperty("--value", String(pct * 100));

      // Color gradient via DaisyUI text-color classes
      const colorClasses = [
        "text-error",
        "text-warning",
        "text-accent",
        "text-success",
        "text-secondary",
      ];
      elSuperRing.classList.remove(...colorClasses);
      if (pct < 0.25) elSuperRing.classList.add("text-error");
      else if (pct < 0.5) elSuperRing.classList.add("text-warning");
      else if (pct < 0.75) elSuperRing.classList.add("text-accent");
      else if (pct < 1) elSuperRing.classList.add("text-success");
      else elSuperRing.classList.add("text-secondary"); // neon purple = READY
    }

    // Pulse glow when super is fully charged
    if (elSuperRing) {
      if (state.superCharge >= maxCharge) {
        elSuperRing.classList.add("animate-pulse");
        elSuperRing.style.filter = "drop-shadow(0 0 8px #a855f7)";
      } else {
        elSuperRing.classList.remove("animate-pulse");
        elSuperRing.style.filter = "";
      }
    }

    // Boss HP bar update (visible during boss phase while HP > 0)
    if (elBossBar) {
      if (state.phase === "boss" && state.bossHp > 0 && state.bossMaxHp > 0) {
        elBossBar.classList.remove("hidden");
        const hp = Math.max(0, state.bossHp);
        if (elBossHp) {
          const percent = (hp / state.bossMaxHp) * 100;
          elBossHp.value = percent;

          // Color-code boss HP bar based on config thresholds
          const colorClasses = [
            "progress-success",
            "progress-warning",
            "progress-accent",
            "progress-error",
          ];
          elBossHp.classList.remove(...colorClasses);
          if (percent > thresholds.high * 100) {
            elBossHp.classList.add("progress-success");
          } else if (percent > thresholds.medium * 100) {
            elBossHp.classList.add("progress-warning");
          } else if (percent > thresholds.low * 100) {
            elBossHp.classList.add("progress-accent");
          } else {
            elBossHp.classList.add("progress-error");
          }
        }
        if (elBossHpText) {
          elBossHpText.innerText = `${hp}/${state.bossMaxHp}`;
        }
      } else {
        elBossBar.classList.add("hidden");
      }
    }

    // Phase alerts
    if (elPhase) {
      if (state.phase === "boss") {
        elPhase.innerText = "BULL MARKET";
        elPhase.classList.remove("hidden");
      } else if (state.phase === "victory") {
        elPhase.innerText = "VICTORY";
        elPhase.classList.remove("hidden", "badge-primary");
        elPhase.classList.add("badge-success");
      } else {
        elPhase.classList.add("hidden");
      }
    }
  });
  document.addEventListener(
    "astro:before-preparation",
    () => {
      unsub();
      btnPause?.removeEventListener("click", handlePauseClick);
    },
    {once: true}
  );
</script>

<style>
  /*
   * Height-based responsive breakpoints for landscape-only game.
   * Mobile landscape: viewport height ≤ ~500px → show emoji labels
   * Desktop/tablet:   viewport height ≥ 520px  → show text labels
   */
  .hud-emoji {
    display: inline;
  }
  .hud-label {
    display: none;
  }

  @media (min-height: 520px) {
    .hud-emoji {
      display: none;
    }
    .hud-label {
      display: inline;
    }

    /* Upsize padding, text, gaps at desktop height */
    .hud-desktop\:p-2 {
      padding: 0.5rem;
    }
    .hud-desktop\:p-4 {
      padding: 1rem;
    }
    .hud-desktop\:px-3 {
      padding-left: 0.75rem;
      padding-right: 0.75rem;
    }
    .hud-desktop\:px-4 {
      padding-left: 1rem;
      padding-right: 1rem;
    }
    .hud-desktop\:px-6 {
      padding-left: 1.5rem;
      padding-right: 1.5rem;
    }
    .hud-desktop\:gap-2 {
      gap: 0.5rem;
    }
    .hud-desktop\:gap-4 {
      gap: 1rem;
    }
    .hud-desktop\:pb-4 {
      padding-bottom: 1rem;
    }
    .hud-desktop\:text-\[10px\] {
      font-size: 10px;
    }
    .hud-desktop\:text-xs {
      font-size: 0.75rem;
      line-height: 1rem;
    }
    .hud-desktop\:text-lg {
      font-size: 1.125rem;
      line-height: 1.75rem;
    }
    .hud-desktop\:text-xl {
      font-size: 1.25rem;
      line-height: 1.75rem;
    }
    .hud-desktop\:w-40 {
      width: 10rem;
    }
    .hud-desktop\:p-1\.5 {
      padding: 0.375rem;
    }
    .hud-desktop\:badge-lg {
      /* daisyUI badge-lg */
    }
    .hud-desktop\:btn-md {
      /* daisyUI btn-md */
    }
  }

  @media (min-height: 768px) {
    .hud-tall\:text-3xl {
      font-size: 1.875rem;
      line-height: 2.25rem;
    }
    .hud-tall\:w-48 {
      width: 12rem;
    }
  }
</style>
