---
import BaseLayout from "@/layouts/BaseLayout.astro";
import HowToPlayModal from "@/components/game/HowToPlayModal.astro";
import LeaderboardModal from "@/components/game/LeaderboardModal.astro";
import Loader from "@/components/game/Loader.astro";
import LoginButton from "@/components/auth/LoginButton.astro";
import VaultBalance from "@/components/wallet/VaultBalance.astro";
import BurnStats from "@/components/wallet/BurnStats.astro";
import Footer from "@/components/user/Footer.astro";
import type {ConfigTypes} from "@/types/config.ts";
import {config} from "@/lib/config/client.ts";

const appName: ConfigTypes["app"]["name"] = config.app.name;
const timeLimitMinutes = Math.floor(config.gameplay.time_limit_seconds / 60);
---

<BaseLayout title={appName}>
  <Loader />

  <!-- Wallpaper Background (ticket #189) -->
  <div
    id="wallpaper-bg"
    class="pointer-events-none fixed inset-0 z-[-2] bg-cover bg-center bg-no-repeat opacity-0 transition-opacity duration-1000"
  >
  </div>

  <!-- Terminal Grid Background -->
  <div
    class="pointer-events-none fixed inset-0 z-[-1] bg-[linear-gradient(rgba(18,16,11,0.8)_2px,transparent_2px),linear-gradient(90deg,rgba(18,16,11,0.8)_2px,transparent_2px)] bg-[size:40px_40px] opacity-20"
  >
  </div>

  <div id="main-content" class="transition-opacity duration-1000">
    <div
      class="hero relative flex min-h-dvh flex-col justify-end pb-8 md:justify-center md:pb-12"
    >
      <div class="hero-content z-10 px-2 text-center md:px-4">
        <div class="max-w-3xl">
          <h1
            class="font-display text-primary mb-0 text-xl font-black tracking-tighter drop-shadow-[0_0_10px_rgba(var(--primary),0.8)] md:mb-2 md:text-5xl lg:text-7xl"
          >
            {appName}
          </h1>
          <p
            class="border-secondary/20 bg-base-100/50 my-0 rounded-lg border px-3 py-0.5 font-mono text-sm tracking-widest uppercase backdrop-blur md:my-8 md:py-6 md:text-xl lg:text-2xl"
          >
            <span class="text-info">COLLECT KEYS.</span>{" "}
            <span class="text-error">FIGHT ENEMIES.</span>{" "}
            <span class="text-warning italic">CLAIM THE $TRESR.</span>
          </p>

          <div class="mt-0.5 flex flex-col items-center gap-0 md:mt-8 md:gap-6">
            <div class="-mb-3 flex flex-col gap-1 md:mb-0 md:flex-row md:gap-4">
              <LoginButton />
            </div>

            <div
              class="grid w-full max-w-4xl grid-cols-2 gap-1 opacity-80 md:grid-cols-3 md:gap-6"
            >
              <div class="stats bg-base-200/50 border-primary/20 border shadow">
                <div class="stat place-items-center">
                  <div class="stat-title font-mono text-xs">OBJECTIVE</div>
                  <div class="stat-value text-primary text-xl md:text-3xl">
                    COLLECT
                  </div>
                  <div class="stat-desc">Gather Keys</div>
                </div>
              </div>
              <div id="vault-display" class="hidden md:block">
                <VaultBalance />
              </div>
              <div class="stats bg-base-200/50 border-primary/20 border shadow">
                <div class="stat place-items-center">
                  <div class="stat-title font-mono text-xs">THREAT</div>
                  <div class="stat-value text-secondary text-xl md:text-3xl">
                    SURVIVE
                  </div>
                  <div class="stat-desc">{timeLimitMinutes} Minutes</div>
                </div>
              </div>
            </div>

            <BurnStats />
          </div>
        </div>
      </div>
    </div>

    <!-- Bottom Corner Buttons -->
    <div
      class="tooltip tooltip-right fixed bottom-8 left-8 z-30"
      data-tip="Leaderboard"
    >
      <a
        id="btn-leaderboard"
        href="#leaderboard"
        role="button"
        aria-label="Open Leaderboard"
        class="btn btn-ghost text-primary hover:bg-primary/10 hover:border-primary/50 gap-2 border border-transparent font-mono"
      >
        <span class="text-xl">🏆</span>
        <span class="hidden lg:inline">LEADERBOARD</span>
      </a>
    </div>

    <div
      class="tooltip tooltip-left fixed right-8 bottom-8 z-30"
      data-tip="Manual"
    >
      <a
        id="btn-manual"
        href="#manual"
        role="button"
        aria-label="Open Game Manual"
        class="btn btn-ghost text-primary hover:bg-primary/10 hover:border-primary/50 gap-2 border border-transparent font-mono"
      >
        <span class="hidden lg:inline">MANUAL</span>
        <span class="text-xl">❓</span>
      </a>
    </div>

    <Footer />
  </div>

  <HowToPlayModal />
  <LeaderboardModal />
</BaseLayout>

<script>
  import {config} from "@/lib/config/client";

  // Wallpaper rotation (ticket #189)
  const LAST_WALLPAPER_KEY = "tresr_last_wallpaper";

  function selectWallpaper(): string {
    const wallpapers = config.assets.wallpapers;
    if (wallpapers.length === 0) return "";

    let last: string | null = null;
    try {
      last = localStorage.getItem(LAST_WALLPAPER_KEY);
    } catch {
      // Private browsing or restricted environment
    }

    let candidates = wallpapers;
    if (last && wallpapers.length > 1) {
      candidates = wallpapers.filter((w) => w !== last);
    }

    const selected = candidates[Math.floor(Math.random() * candidates.length)];
    try {
      localStorage.setItem(LAST_WALLPAPER_KEY, selected);
    } catch {
      // Quota exceeded or restricted environment
    }
    return selected;
  }

  let wallpaperImg: HTMLImageElement | null = null;

  const wallpaper = selectWallpaper();
  if (wallpaper) {
    const bg = document.getElementById("wallpaper-bg");
    if (bg) {
      wallpaperImg = new Image();
      wallpaperImg.onload = () => {
        bg.style.backgroundImage = `url('${wallpaperImg!.src}')`;
        bg.classList.remove("opacity-0");
        bg.classList.add("opacity-30");
      };
      wallpaperImg.onerror = () => {
        // Fallback: leave without wallpaper
      };
      wallpaperImg.src = `/assets/images/wallpapers/${wallpaper}.webp`;
    }
  }

  // Handle fade-in after loader — no-op now (opacity-0 removed for FCP/LCP)
  function handleLoaderReady() {
    // Content is already visible; Loader overlay fades out independently
  }
  window.addEventListener("loader-ready", handleLoaderReady);

  // Modal triggers
  function handleLeaderboardClick() {
    document.dispatchEvent(new CustomEvent("tresr:open-leaderboard"));
  }

  function handleManualClick() {
    document.dispatchEvent(new CustomEvent("tresr:open-how-to-play"));
  }

  const btnLeaderboard = document.getElementById("btn-leaderboard");
  const btnManual = document.getElementById("btn-manual");
  btnLeaderboard?.addEventListener("click", handleLeaderboardClick);
  btnManual?.addEventListener("click", handleManualClick);

  // Vault status — lock START button when vault is below minimum cap
  const loginBtn = document.getElementById("login-button");
  let originalLoginText = loginBtn?.textContent?.trim() ?? "LOGIN";
  let vaultLocked = false;

  function handleVaultStatus(e: Event) {
    const {locked} = (e as CustomEvent).detail;
    if (!loginBtn) return;

    if (locked && !vaultLocked) {
      vaultLocked = true;
      loginBtn.setAttribute("disabled", "true");
      loginBtn.classList.add("btn-disabled", "opacity-50");
      loginBtn.textContent = "RECHARGING";
    } else if (!locked && vaultLocked) {
      vaultLocked = false;
      loginBtn.removeAttribute("disabled");
      loginBtn.classList.remove("btn-disabled", "opacity-50");
      loginBtn.textContent = originalLoginText;
    }
  }

  document.addEventListener("tresr:vault-status", handleVaultStatus);

  document.addEventListener(
    "astro:before-preparation",
    () => {
      window.removeEventListener("loader-ready", handleLoaderReady);
      btnLeaderboard?.removeEventListener("click", handleLeaderboardClick);
      btnManual?.removeEventListener("click", handleManualClick);
      document.removeEventListener("tresr:vault-status", handleVaultStatus);
      if (wallpaperImg) {
        wallpaperImg.onload = null;
        wallpaperImg.onerror = null;
        wallpaperImg.src = "";
        wallpaperImg = null;
      }
    },
    {once: true}
  );
</script>
