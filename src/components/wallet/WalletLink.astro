---
import {config} from "@/lib/config/client";
import {JUNO_ENVIRONMENT} from "@/lib/config/constants";

const envKey =
  JUNO_ENVIRONMENT === "development"
    ? ("anvil" as const)
    : JUNO_ENVIRONMENT === "staging"
      ? ("testnet" as const)
      : ("mainnet" as const);
const tokenSymbol = `$${config.blockchain.avalanche[envKey].token_ticker}`;
---

<details class="dropdown dropdown-end">
  <summary
    class="btn btn-ghost btn-circle text-xl"
    title="Wallet"
    id="wallet-bell"
  >
    💰
  </summary>
  <div
    class="card card-compact dropdown-content bg-base-100 border-primary/20 z-[1] mt-3 w-72 border shadow-xl"
  >
    <div class="card-body">
      <!-- State: Not logged in -->
      <div id="wallet-state-unauthenticated">
        <h3 class="text-lg font-bold">Wallet</h3>
        <p class="text-sm opacity-70">
          Please sign in to access wallet features.
        </p>
      </div>

      <!-- State: Guest -->
      <div id="wallet-state-guest" class="hidden">
        <h3 class="text-lg font-bold">Wallet</h3>
        <p class="text-sm opacity-70">
          Guests cannot connect a wallet. Sign in as a degen to link your
          wallet.
        </p>
      </div>

      <!-- State: IID, no wallet linked -->
      <div id="wallet-state-unlinked" class="hidden">
        <h3 class="text-lg font-bold">No Wallet Linked</h3>
        <p class="mt-1 text-sm opacity-70">
          Link your wallet in the Player Profile to view your balance.
        </p>
        <button
          id="wallet-open-profile"
          class="btn btn-primary btn-sm mt-3 w-full"
        >
          Open Profile
        </button>
      </div>

      <!-- State: Wallet linked (IID+linked or SIWA) -->
      <div id="wallet-state-linked" class="hidden">
        <h3 class="text-lg font-bold">Wallet Balance</h3>

        <!-- Balance display -->
        <div class="bg-base-200 mt-2 rounded p-3">
          <!-- Loading state -->
          <div id="wallet-balance-loading" class="flex items-center gap-2">
            <span class="loading loading-spinner loading-sm"></span>
            <span class="text-sm opacity-70">Fetching balance...</span>
          </div>

          <!-- Balance value -->
          <div id="wallet-balance-value" class="hidden">
            <div class="flex items-center justify-between">
              <span
                id="wallet-balance-amount"
                class="text-warning font-mono text-xl font-bold"
              >
                0.00
              </span>
              <span
                id="wallet-balance-symbol"
                class="text-warning text-sm font-semibold"
              >
                {tokenSymbol}
              </span>
            </div>
          </div>

          <!-- Error state -->
          <div id="wallet-balance-error" class="hidden">
            <span class="text-error text-sm">Failed to fetch balance</span>
          </div>
        </div>

        <!-- Address -->
        <div
          id="wallet-address"
          class="mt-2 text-center font-mono text-xs opacity-50"
        >
        </div>

        <!-- Refresh button -->
        <div class="mt-2 flex justify-end">
          <button
            id="wallet-refresh-btn"
            class="btn btn-ghost btn-xs gap-1"
            title="Refresh balance"
          >
            <span id="wallet-refresh-icon">♻️</span>
            <span id="wallet-refresh-label" class="text-xs">Refresh</span>
          </button>
        </div>

        <!-- Cooldown indicator -->
        <div id="wallet-cooldown" class="mt-1 hidden text-right">
          <span class="text-xs opacity-50">
            Wait <span id="wallet-cooldown-seconds">0</span>s
          </span>
        </div>
      </div>

      <!-- Connect wallet button (for IID users who need to connect before linking) -->
      <div id="wallet-state-connect" class="hidden">
        <h3 class="text-lg font-bold">Wallet</h3>
        <div id="wallet-connect-status" class="mb-2 text-xs opacity-70">
          Not connected
        </div>
        <button id="wallet-connect-btn" class="btn btn-primary btn-sm w-full">
          Connect Wallet
        </button>
        <button
          id="wallet-link-btn"
          class="btn btn-secondary btn-sm mt-2 hidden w-full"
        >
          Link to Account
        </button>
      </div>
    </div>
  </div>
</details>

<script>
  import {getAuthState, type AuthState} from "@/lib/auth";
  import {authStore} from "@/lib/auth/store";
  import {profileStore} from "@/lib/user/store";
  import {
    getUserProfile,
    saveUserProfile,
    createDefaultProfile,
  } from "@/lib/user";
  // connectWallet, getWalletClient (from wallet/connection),
  // buildWalletLinkMessage (from wallet/wallet-message), and shortenAddress
  // (from wallet/avalanche) are lazy-imported ONLY inside handleConnect /
  // handleLink click handlers — this keeps the heavy @reown/appkit + @wagmi/core
  // + viem bundle out of the initial page JS for users who never click Connect.
  import {
    getTresrBalance,
    formatBalance,
    isRpcAvailable,
    resetRpcAvailability,
  } from "@/lib/blockchain/balance";
  import {shortenAddress} from "@/lib/blockchain/networks/display";
  import {JUNO_ENVIRONMENT} from "@/lib/config/constants";
  import {log} from "@/lib/utils/log";
  import {config} from "@/lib/config/client";

  const COMPONENT_NAME = "WalletLink";
  const COOLDOWN_MS = config.wallet.balance_refresh_cooldown_ms;

  // DOM elements
  const stateUnauthenticated = document.getElementById(
    "wallet-state-unauthenticated"
  )!;
  const stateGuest = document.getElementById("wallet-state-guest")!;
  const stateUnlinked = document.getElementById("wallet-state-unlinked")!;
  const stateLinked = document.getElementById("wallet-state-linked")!;
  const stateConnect = document.getElementById("wallet-state-connect")!;

  const balanceLoading = document.getElementById("wallet-balance-loading")!;
  const balanceValue = document.getElementById("wallet-balance-value")!;
  const balanceAmount = document.getElementById("wallet-balance-amount")!;
  const balanceSymbol = document.getElementById("wallet-balance-symbol")!;
  const balanceError = document.getElementById("wallet-balance-error")!;
  const addressEl = document.getElementById("wallet-address")!;
  const refreshBtn = document.getElementById(
    "wallet-refresh-btn"
  ) as HTMLButtonElement;
  const refreshLabel = document.getElementById("wallet-refresh-label")!;
  const cooldownEl = document.getElementById("wallet-cooldown")!;
  const cooldownSeconds = document.getElementById("wallet-cooldown-seconds")!;
  const openProfileBtn = document.getElementById(
    "wallet-open-profile"
  ) as HTMLButtonElement;
  const connectBtn = document.getElementById(
    "wallet-connect-btn"
  ) as HTMLButtonElement;
  const linkBtn = document.getElementById(
    "wallet-link-btn"
  ) as HTMLButtonElement;
  const connectStatus = document.getElementById("wallet-connect-status")!;

  // State
  let lastRefreshTime = 0;
  let cooldownTimer: ReturnType<typeof setInterval> | null = null;
  let currentAddress: string | null = null;
  let updateGeneration = 0;
  let disposed = false;

  // Token symbol from config based on environment
  const envKey =
    JUNO_ENVIRONMENT === "development"
      ? "anvil"
      : JUNO_ENVIRONMENT === "staging"
        ? "testnet"
        : "mainnet";
  const tokenSymbol = `$${config.blockchain.avalanche[envKey].token_ticker}`;

  function hideAllStates() {
    stateUnauthenticated.classList.add("hidden");
    stateGuest.classList.add("hidden");
    stateUnlinked.classList.add("hidden");
    stateLinked.classList.add("hidden");
    stateConnect.classList.add("hidden");
  }

  function showState(el: HTMLElement) {
    hideAllStates();
    el.classList.remove("hidden");
  }

  function showBalanceLoading() {
    balanceLoading.classList.remove("hidden");
    balanceValue.classList.add("hidden");
    balanceError.classList.add("hidden");
  }

  function showBalanceValue(formatted: string) {
    balanceLoading.classList.add("hidden");
    balanceValue.classList.remove("hidden");
    balanceError.classList.add("hidden");
    balanceAmount.textContent = formatted;
    balanceSymbol.textContent = tokenSymbol;
  }

  function showBalanceError() {
    balanceLoading.classList.add("hidden");
    balanceValue.classList.add("hidden");
    balanceError.classList.remove("hidden");
  }

  function canRefresh(): boolean {
    return Date.now() - lastRefreshTime >= COOLDOWN_MS;
  }

  function startCooldownTimer() {
    if (disposed) return;
    if (cooldownTimer) clearInterval(cooldownTimer);

    refreshBtn.disabled = true;
    refreshLabel.textContent = "Wait...";
    cooldownEl.classList.remove("hidden");

    cooldownTimer = setInterval(() => {
      if (disposed) {
        clearInterval(cooldownTimer!);
        cooldownTimer = null;
        return;
      }
      const remaining = Math.max(
        0,
        COOLDOWN_MS - (Date.now() - lastRefreshTime)
      );
      const seconds = Math.ceil(remaining / 1000);
      cooldownSeconds.textContent = String(seconds);

      if (remaining <= 0) {
        if (cooldownTimer) clearInterval(cooldownTimer);
        cooldownTimer = null;
        refreshBtn.disabled = false;
        refreshLabel.textContent = "Refresh";
        cooldownEl.classList.add("hidden");
      }
    }, 1000);
  }

  async function handleRefresh() {
    if (!canRefresh() || !currentAddress) return;
    resetRpcAvailability(); // Re-probe RPC on manual refresh
    lastRefreshTime = Date.now();
    startCooldownTimer();
    showBalanceLoading();

    // Fall back to cached read
    try {
      const balance = await getTresrBalance(currentAddress, false);
      if (isRpcAvailable()) {
        showBalanceValue(formatBalance(balance));
        addressEl.textContent = shortenAddress(currentAddress);
        // Refresh Vault Balance independently
        const {getVaultCurrentBalance} = await import(
          "@/lib/blockchain/contracts/vault"
        );
        const vaultBal = await getVaultCurrentBalance();
        document.dispatchEvent(
          new CustomEvent("tresr:blockchain-synced", {
            detail: {vaultBalance: vaultBal},
          })
        );
      } else {
        showBalanceError();
      }
    } catch {
      showBalanceError();
    }
  }

  async function showLinkedState(address: string) {
    if (currentAddress === address) return;
    currentAddress = address;
    showState(stateLinked);
    addressEl.textContent = shortenAddress(address);
    // Use cached balance for initial display (fast), then fire a full sync
    // in the background so Juno gets updated without blocking the UI.
    showBalanceLoading();
    try {
      const balance = await getTresrBalance(address, false);
      showBalanceValue(formatBalance(balance));
      addressEl.textContent = shortenAddress(address);

      const {getVaultCurrentBalance} = await import(
        "@/lib/blockchain/contracts/vault"
      );
      const vaultBal = await getVaultCurrentBalance();
      document.dispatchEvent(
        new CustomEvent("tresr:blockchain-synced", {
          detail: {vaultBalance: vaultBal},
        })
      );
    } catch {
      showBalanceError();
    }
  }

  async function updateUI(authState: AuthState) {
    const gen = ++updateGeneration;

    if (!authState.isAuthenticated) {
      showState(stateUnauthenticated);
      currentAddress = null;
      return;
    }

    if (authState.isGuest) {
      showState(stateGuest);
      currentAddress = null;
      return;
    }

    // Authenticated user — check in-memory store first to avoid a redundant
    // Juno read when auth fires before loadProfile has completed (e.g. SIWA).
    const cachedProfile = profileStore.get();
    if (cachedProfile?.evm_wallet) {
      await showLinkedState(cachedProfile.evm_wallet);
      return;
    }

    // Store miss — fetch from Juno (first load or cache not yet populated)
    if (authState.user) {
      try {
        const doc = await getUserProfile(authState.user.key);
        if (gen !== updateGeneration) return; // Stale — newer update superseded
        if (doc?.data?.evm_wallet) {
          await showLinkedState(doc.data.evm_wallet);
          return;
        }
      } catch (e) {
        log.error(COMPONENT_NAME, "Failed to check profile", e);
      }
    }

    if (gen !== updateGeneration) return; // Stale — newer update superseded

    // Not linked
    showState(stateUnlinked);
    currentAddress = null;
  }

  // Refresh button handler
  refreshBtn.addEventListener("click", handleRefresh);

  // Animate the refresh icon while a blockchain sync is in progress
  function handleBlockchainSyncing(e: Event) {
    const {syncing} = (e as CustomEvent<{syncing: boolean}>).detail;
    const icon = document.getElementById("wallet-refresh-icon")!;
    if (syncing) {
      icon.classList.add("animate-spin");
    } else {
      icon.classList.remove("animate-spin");
    }
  }
  document.addEventListener(
    "tresr:blockchain-syncing",
    handleBlockchainSyncing
  );

  // Page-focus trigger: re-sync when user tabs back, if wallet is connected
  function handleVisibilityChange() {
    if (document.visibilityState === "visible" && currentAddress) {
      void getTresrBalance(currentAddress, false).then((balance) => {
        showBalanceValue(formatBalance(balance));
      });
    }
  }
  document.addEventListener("visibilitychange", handleVisibilityChange);

  // Named handlers for cleanup (ticket #241)
  function handleOpenProfile() {
    document.dispatchEvent(new CustomEvent("tresr:open-profile"));
    // Close dropdown (details/summary pattern)
    const details = openProfileBtn.closest("details.dropdown");
    details?.removeAttribute("open");
  }
  async function handleConnect() {
    try {
      // Lazy-load the AppKit bundle only when user clicks Connect
      const [{connectWallet}, {shortenAddress: shortAddr}] = await Promise.all([
        import("@/lib/wallet/connection"),
        import("@/lib/blockchain/networks/display"),
      ]);
      const connection = await connectWallet();
      const address = connection.address;
      connectStatus.textContent = `Connected: ${shortAddr(address)}`;

      const authState = getAuthState();
      if (authState.user) {
        const doc = await getUserProfile(authState.user.key);
        if (doc?.data?.evm_wallet?.toLowerCase() === address.toLowerCase()) {
          await showLinkedState(address);
        } else {
          connectBtn.classList.add("hidden");
          linkBtn.classList.remove("hidden");
        }
      }
    } catch (error: unknown) {
      const message = error instanceof Error ? error.message : String(error);
      connectStatus.textContent = `Error: ${message}`;
    }
  }
  async function handleLink() {
    const address = connectStatus.textContent?.match(/0x[a-fA-F0-9]+/)?.[0];
    if (!address) return;

    try {
      // Lazy-load AppKit modules only when user clicks Link
      const [{getWalletClient}, {buildWalletLinkMessage}] = await Promise.all([
        import("@/lib/wallet/connection"),
        import("@/lib/wallet/wallet-message"),
      ]);
      const walletClient = await getWalletClient();
      const authState = getAuthState();
      if (!authState.user) throw new Error("Sign in with IID first.");

      const principal = authState.user.key;
      const message = buildWalletLinkMessage(
        principal,
        address as `0x${string}`
      );
      const signature = await walletClient.signMessage({
        account: address as `0x${string}`,
        message,
      });

      const existingProfile = await getUserProfile(principal);
      const profile = {
        ...(existingProfile?.data || createDefaultProfile(principal)),
        evm_wallet: address,
        verification_signature: signature,
        verification_message: message,
      };

      await saveUserProfile(principal, profile, existingProfile?.version);
      profileStore.set(profile);

      await showLinkedState(address);
    } catch (error) {
      connectStatus.textContent = `Error: ${error instanceof Error ? error.message : String(error)}`;
    }
  }

  openProfileBtn.addEventListener("click", handleOpenProfile);
  connectBtn.addEventListener("click", handleConnect);
  linkBtn.addEventListener("click", handleLink);

  // Subscribe to auth changes (ticket #199: store cleanup on navigation)
  const unsubAuth = authStore.subscribe((state) => {
    updateUI(state);
  });

  const unsubProfile = profileStore.subscribe((profile) => {
    if (profile?.evm_wallet) {
      const authState = getAuthState();
      if (authState.isAuthenticated && !authState.isGuest) {
        // Skip if the auth subscription already handled this address
        if (currentAddress === profile.evm_wallet) return;
        showLinkedState(profile.evm_wallet);
      }
    }
  });

  document.addEventListener(
    "astro:before-preparation",
    () => {
      disposed = true;
      unsubAuth();
      unsubProfile();
      if (cooldownTimer) clearInterval(cooldownTimer);
      refreshBtn.removeEventListener("click", handleRefresh);
      openProfileBtn.removeEventListener("click", handleOpenProfile);
      connectBtn.removeEventListener("click", handleConnect);
      linkBtn.removeEventListener("click", handleLink);
      document.removeEventListener(
        "tresr:blockchain-syncing",
        handleBlockchainSyncing
      );
      document.removeEventListener("visibilitychange", handleVisibilityChange);
    },
    {once: true}
  );
</script>
