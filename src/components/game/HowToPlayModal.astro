---
import {unified} from "unified";
import remarkParse from "remark-parse";
import remarkGfm from "remark-gfm";
import remarkEmoji from "remark-emoji";
import remarkBreaks from "remark-breaks";
import remarkRehype from "remark-rehype";
import rehypeStringify from "rehype-stringify";
import type {ConfigTypes} from "@/types/config.ts";
import {config} from "@/lib/config/client.ts";

const processor = unified()
  .use(remarkParse)
  .use(remarkGfm)
  .use(remarkEmoji)
  .use(remarkBreaks)
  .use(remarkRehype)
  .use(rehypeStringify);

const instructions: ConfigTypes["app"]["instructions"] = processor
  .processSync(config.app.instructions)
  .toString();
---

<dialog id="how-to-play-modal" class="modal">
  <div class="modal-box border-primary/30 bg-base-200 w-11/12 max-w-3xl border">
    <div class="mb-6 flex items-center justify-between">
      <h2 class="text-primary text-2xl font-black tracking-widest">
        HOW TO PLAY
      </h2>
      <button
        id="btn-close-how-to-play"
        class="btn btn-circle btn-ghost min-h-[44px] min-w-[44px] text-lg"
        >✕</button
      >
    </div>

    <div
      class="prose prose-headings:text-xl prose-p:my-2 prose-h2:my-4 prose-li:my-1 prose-ol:my-0 prose-ul:my-0 prose-invert prose-sm max-w-none leading-snug break-words"
    >
      <div set:html={instructions} />
    </div>
  </div>
  <form method="dialog" class="modal-backdrop">
    <button id="btn-backdrop-close-how-to-play">close</button>
  </form>
</dialog>

<script>
  import PWA from "@/lib/pwa";
  import {getAuthState} from "@/lib/auth";
  import {enqueueProfileWrite} from "@/lib/user";
  import {trackModalOpen} from "@/lib/metrics/analytics";

  const modal = document.getElementById(
    "how-to-play-modal"
  ) as HTMLDialogElement;

  async function openHowToPlayModal() {
    modal?.showModal();
    trackModalOpen("how_to_play");
    PWA.getInstance().checkForUpdates();

    // Mark instructions as read
    try {
      const auth = getAuthState();
      if (auth.isAuthenticated && !auth.isGuest && auth.user) {
        await enqueueProfileWrite(auth.user.key, (profile) => ({
          ...profile,
          preferences: {...profile.preferences, has_read_instructions: true},
        }));
      }
    } catch {
      // Non-critical — modal still works if profile update fails
    }
  }

  function closeHowToPlayModal() {
    modal?.close();
  }

  document
    .getElementById("btn-close-how-to-play")
    ?.addEventListener("click", closeHowToPlayModal);
  document
    .getElementById("btn-backdrop-close-how-to-play")
    ?.addEventListener("click", closeHowToPlayModal);

  // Listen for custom event instead of window global (ticket #263)
  function handleOpenHowToPlay() {
    openHowToPlayModal();
  }
  document.addEventListener("tresr:open-how-to-play", handleOpenHowToPlay);

  // Cleanup document-level listener on navigation (ticket #241)
  document.addEventListener(
    "astro:before-preparation",
    () => {
      document.removeEventListener(
        "tresr:open-how-to-play",
        handleOpenHowToPlay
      );
      document
        .getElementById("btn-close-how-to-play")
        ?.removeEventListener("click", closeHowToPlayModal);
      document
        .getElementById("btn-backdrop-close-how-to-play")
        ?.removeEventListener("click", closeHowToPlayModal);
    },
    {once: true}
  );
</script>
