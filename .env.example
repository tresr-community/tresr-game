# Juno Satellite Configuration

# Local Internet Identity Canister ID (Default for Juno Emulator is rdmx6-jaaaa-aaaaa-aaadq-cai)
VITE_INTERNET_IDENTITY_ID=rdmx6-jaaaa-aaaaa-aaadq-cai

# Define your Satellite ID.
VITE_SATELLITE_ID=your-satellite-id-here

# Astro Site URL (Final deployed URL)
VITE_ASTRO_SITE_URL=https://myapp.mydomain.com

# Juno Orbiter ID for analytics.
VITE_ORBITER_ID=orbiter-id-goes-here

# IC SIWA Canister ID (Sign In With Avalanche)
# Managed externally - obtain from ic-siwa project
VITE_SIWA_PROVIDER_ID=canister-id-goes-here

# NOTES:
#   For Development,
#     Any changes to the Satellite ID require a 'direnv reload' to apply.
#     You can get the ID from http://localhost:5866
#   For Production,
#     Set VITE_SATELLITE_ID to your production satellite ID in CI.
#     You can get the ID from https://console.juno.build
