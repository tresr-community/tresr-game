---

---

<dialog id="profile-modal" class="modal">
  <div class="modal-box border-primary/30 bg-base-200 w-11/12 max-w-lg border">
    <div class="mb-6 flex items-center justify-between">
      <h2 class="text-primary text-2xl font-black tracking-widest uppercase">
        Player Profile
      </h2>
      <button
        id="btn-close-profile"
        class="btn btn-circle btn-ghost min-h-[44px] min-w-[44px] text-lg"
        >✕</button
      >
    </div>

    <div id="profile-loading" class="py-10 text-center">
      <span class="loading loading-spinner loading-lg text-primary"></span>
      <p class="text-primary mt-2 animate-pulse font-mono text-xs">
        SCANNED BIOMETRICS...
      </p>
    </div>

    <div id="profile-content" class="hidden space-y-6">
      <!-- Avatar Upload -->
      <div class="flex justify-center">
        <div class="group relative cursor-pointer" id="avatar-wrapper">
          <!-- Avatar circle -->
          <div id="avatar-display" class="avatar placeholder">
            <div
              id="avatar-inner"
              class="bg-primary/20 text-primary border-primary/30 ring-primary/10 ring-offset-base-200 w-16 overflow-hidden rounded-full border-2 ring ring-offset-2"
            >
              <img
                id="avatar-img"
                class="hidden h-full w-full object-cover"
                alt="Avatar"
              />
              <span id="avatar-letter" class="text-xl font-black">?</span>
            </div>
          </div>
          <!-- Hover overlay -->
          <div
            class="pointer-events-none absolute inset-0 flex items-center justify-center rounded-full bg-black/60 opacity-0 transition-opacity group-hover:opacity-100"
          >
            <span
              class="text-[10px] font-bold tracking-wider text-white uppercase"
              >Change</span
            >
          </div>
          <!-- Upload spinner -->
          <div
            id="avatar-uploading"
            class="absolute inset-0 flex hidden items-center justify-center rounded-full bg-black/70"
          >
            <span class="loading loading-spinner loading-sm text-primary"
            ></span>
          </div>
        </div>
        <input
          type="file"
          id="avatar-file-input"
          accept="image/jpeg,image/png,image/webp"
          class="hidden"
        />
      </div>

      <!-- Nickname (Editable) -->
      <div class="form-control w-full">
        <label class="label">
          <span
            class="label-text text-primary font-bold tracking-widest uppercase"
            >Degen Handle</span
          >
        </label>
        <div class="flex gap-2">
          <input
            type="text"
            id="input-nickname"
            placeholder="Enter handle..."
            class="input input-bordered input-primary bg-base-300 w-full font-mono"
          />
        </div>
      </div>

      <!-- Email (Optional) -->
      <div class="form-control w-full">
        <label class="label">
          <span
            class="label-text text-primary font-bold tracking-widest uppercase"
            >Secure Comms (Email)</span
          >
        </label>
        <input
          type="email"
          id="input-email"
          placeholder="spam@tresr.community"
          class="input input-bordered input-primary bg-base-300 w-full font-mono"
        />
      </div>

      <!-- Principal ID (Read-only) -->
      <div class="form-control w-full">
        <label class="label">
          <span
            class="label-text text-neutral-content/50 font-bold tracking-widest uppercase"
            >Identity (Principal)</span
          >
        </label>
        <div
          id="display-principal"
          class="bg-base-300 truncate rounded-lg p-3 font-mono text-xs break-all opacity-70 select-all"
        >
          -
        </div>
      </div>

      <!-- Avalanche Wallet -->
      <div
        class="collapse-arrow border-base-content/10 bg-base-300 collapse border"
      >
        <input type="checkbox" checked="checked" />
        <div
          class="collapse-title text-sm font-bold tracking-tighter uppercase"
        >
          Avalanche Wallet
        </div>
        <div class="collapse-content space-y-4 pt-4">
          <!-- Not Linked State -->
          <div id="wallet-status-unlinked" class="hidden">
            <button
              type="button"
              id="btn-link-wallet"
              class="btn btn-accent btn-sm w-full gap-2"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="currentColor"
                class="h-5 w-5"
              >
                <path
                  d="M2.273 5.625A4.483 4.483 0 015.25 4.5h13.5c1.141 0 2.183.425 2.977 1.125A3 3 0 0018.75 3H5.25a3 3 0 00-2.977 2.625zM2.273 8.625A4.483 4.483 0 015.25 7.5h13.5c1.141 0 2.183.425 2.977 1.125A3 3 0 0018.75 6H5.25a3 3 0 00-2.977 2.625zM5.25 9a3 3 0 00-3 3v6a3 3 0 003 3h13.5a3 3 0 003-3v-6a3 3 0 00-3-3H15a.75.75 0 00-.75.75 2.25 2.25 0 01-4.5 0A.75.75 0 009 9H5.25z"
                ></path>
              </svg>
              Link Wallet
            </button>
          </div>

          <!-- Linked State (Manual Link) -->
          <div id="wallet-status-linked" class="hidden">
            <div role="alert" class="alert alert-success mb-4 px-3 py-2">
              <span class="text-[10px] font-bold uppercase"
                >Link Established</span
              >
              <span
                id="wallet-address-display"
                class="ml-auto font-mono text-xs opacity-80">0x...</span
              >
            </div>
            <button
              type="button"
              id="btn-unlink-wallet"
              class="btn btn-error btn-outline btn-sm w-full">SEVER LINK</button
            >
          </div>

          <!-- SIWA Primary Identity State -->
          <div id="wallet-status-siwa" class="hidden">
            <div role="alert" class="alert alert-info mb-4 px-3 py-2">
              <span class="text-[10px] font-bold uppercase"
                >Primary Identity</span
              >
              <span
                id="wallet-address-siwa"
                class="ml-auto font-mono text-xs opacity-80">0x...</span
              >
            </div>
            <p class="text-base-content/50 text-xs italic">
              This wallet was used to sign in and cannot be unlinked.
            </p>
          </div>
        </div>
      </div>

      <!-- Global Stats Preview -->
      <div class="stats stats-vertical bg-base-200/50 w-full shadow">
        <div class="stat place-items-center py-3">
          <div class="stat-title text-[10px] uppercase">High Score</div>
          <div
            id="stat-highscore"
            class="stat-value text-primary font-mono text-xl"
          >
            0
          </div>
        </div>
        <div class="stat place-items-center py-3">
          <div class="stat-title text-[10px] uppercase">Games Played</div>
          <div
            id="stat-games-played"
            class="stat-value text-accent font-mono text-xl"
          >
            0
          </div>
        </div>
        <div class="stat place-items-center py-3">
          <div class="stat-title text-[10px] uppercase">Games Won</div>
          <div
            id="stat-games-won"
            class="stat-value text-success font-mono text-xl"
          >
            0
          </div>
        </div>
        <div class="stat place-items-center py-3">
          <div class="stat-title text-[10px] uppercase">Games Lost</div>
          <div
            id="stat-games-lost"
            class="stat-value text-error font-mono text-xl"
          >
            0
          </div>
        </div>
      </div>

      <!-- Guest note (shown only for guest sessions) -->
      <div
        id="guest-profile-note"
        role="alert"
        class="alert alert-warning hidden text-sm"
      >
        <span>Login to access full profile and link wallet.</span>
      </div>

      <div class="divider"></div>

      <!-- Actions -->
      <div class="mt-2 flex items-center justify-between">
        <a
          href="/claims"
          id="btn-claims"
          class="btn btn-warning btn-outline gap-2 px-6"
        >
          <span class="text-lg">🏆</span>
          Rewards
        </a>
        <button id="btn-save-profile" class="btn btn-primary px-8"
          >Update Identity</button
        >
      </div>
    </div>
  </div>
  <form method="dialog" class="modal-backdrop">
    <button id="btn-backdrop-close-profile">close</button>
  </form>
</dialog>

<!-- Wallet Linking Loading Modal -->
<dialog id="wallet-link-loading-modal" class="modal">
  <div class="modal-box bg-base-100">
    <div class="flex justify-center">
      <div class="loading loading-spinner text-primary"></div>
    </div>
    <p class="mt-2 text-center">Linking wallet...</p>
  </div>
</dialog>

<script>
  import {getAuthState} from "@/lib/auth";
  import {
    getUserProfile,
    saveUserProfile,
    createDefaultProfile,
    genNickName,
    enqueueProfileWrite,
  } from "@/lib/user";
  import {uploadAvatar} from "@/lib/user/avatar";
  import {
    connectWallet,
    getWalletClient,
    disconnectWallet,
  } from "@/lib/wallet/connection";
  import {buildWalletLinkMessage} from "@/lib/wallet/wallet-message";
  import {shortenAddress} from "@/lib/blockchain/networks/display";
  import type {UserProfile} from "@/types/backend";
  import {log} from "@/lib/utils/log";
  import {profileStore} from "@/lib/user/store";
  import {
    trackModalOpen,
    trackProfileUpdate,
    trackAvatarUpload,
    trackWalletLink,
    trackWalletUnlink,
  } from "@/lib/metrics/analytics";

  const COMPONENT_NAME = "ProfileModal";

  const modal = document.getElementById("profile-modal") as HTMLDialogElement;
  const content = document.getElementById("profile-content");
  const loading = document.getElementById("profile-loading");
  const nicknameInput = document.getElementById(
    "input-nickname"
  ) as HTMLInputElement;
  const emailInput = document.getElementById("input-email") as HTMLInputElement;
  const principalDisplay = document.getElementById(
    "display-principal"
  ) as HTMLDivElement;
  const walletAddressDisplay = document.getElementById(
    "wallet-address-display"
  ) as HTMLSpanElement;
  const statHighscore = document.getElementById(
    "stat-highscore"
  ) as HTMLSpanElement;
  const statGamesPlayed = document.getElementById(
    "stat-games-played"
  ) as HTMLSpanElement;
  const statGamesWon = document.getElementById(
    "stat-games-won"
  ) as HTMLSpanElement;
  const statGamesLost = document.getElementById(
    "stat-games-lost"
  ) as HTMLSpanElement;
  const saveBtn = document.getElementById(
    "btn-save-profile"
  ) as HTMLButtonElement;
  const avatarWrapper = document.getElementById("avatar-wrapper");
  const avatarImg = document.getElementById("avatar-img") as HTMLImageElement;
  const avatarLetter = document.getElementById(
    "avatar-letter"
  ) as HTMLSpanElement;
  const avatarFileInput = document.getElementById(
    "avatar-file-input"
  ) as HTMLInputElement;
  const avatarUploading = document.getElementById("avatar-uploading");

  let currentProfile: UserProfile | null = null;
  let currentVersion: bigint | undefined;

  async function openProfileModal() {
    log.info(COMPONENT_NAME, "Opening modal");
    modal?.showModal();
    trackModalOpen("profile");
    await loadProfile();
  }

  async function loadProfile() {
    const auth = getAuthState();
    if (!auth.isAuthenticated) {
      log.warn(COMPONENT_NAME, "User not authenticated, cannot load profile.");
      return;
    }

    loading?.classList.remove("hidden");
    content?.classList.add("hidden");

    try {
      if (auth.isGuest) {
        // ... guest logic ...
        currentProfile = {
          user_id: "guest",
          nickname: "Guest Agent",
          email: "",
          evm_wallet: undefined,
          preferences: {
            theme: "synthwave",
            has_read_instructions: false,
          },
          stats: {
            high_score: 0n,
            total_games_played: 0n,
            total_games_won: 0n,
            total_games_lost: 0n,
          },
        };
        currentVersion = undefined;
        renderGuestProfile();
      } else if (auth.user) {
        const doc = await getUserProfile(auth.user.key);
        if (doc) {
          currentProfile = doc.data;
          currentVersion = doc.version;
          // Fix for missing nickname in existing doc
          if (!currentProfile.nickname) {
            log.warn(
              COMPONENT_NAME,
              "Profile found but nickname missing. Generating new one."
            );
            currentProfile.nickname = genNickName();
            // Save the updated profile
            const savedDoc = await saveUserProfile(
              auth.user.key,
              currentProfile,
              currentVersion
            );
            currentVersion = savedDoc.version;
            currentProfile = savedDoc.data;
          }
        } else {
          currentProfile = createDefaultProfile(auth.user.key);
          // Save the new profile immediately
          const savedDoc = await saveUserProfile(
            auth.user.key,
            currentProfile,
            undefined
          );
          currentVersion = savedDoc.version;
          currentProfile = savedDoc.data;
        }
        renderProfile();
      }
    } catch (err) {
      log.error(COMPONENT_NAME, "Load failed", err);
    } finally {
      loading?.classList.add("hidden");
      content?.classList.remove("hidden");
    }
  }

  function renderProfile() {
    const auth = getAuthState();
    if (!currentProfile || !auth.user) return;

    log.debug(COMPONENT_NAME, "Rendering profile", currentProfile);
    nicknameInput.value = currentProfile.nickname || "";
    emailInput.value = currentProfile.email || "";
    principalDisplay.innerText = auth.user.key;

    statHighscore.innerText = currentProfile.stats.high_score.toString();
    statGamesPlayed.innerText =
      currentProfile.stats.total_games_played.toString();
    statGamesWon.innerText = currentProfile.stats.total_games_won.toString();
    statGamesLost.innerText = currentProfile.stats.total_games_lost.toString();

    // Avatar
    renderAvatar(currentProfile);

    // Ensure guest note is hidden for non-guest sessions
    document.getElementById("guest-profile-note")?.classList.add("hidden");

    updateWalletUI();
  }

  function updateWalletUI() {
    const auth = getAuthState();
    const walletStatusUnlinked = document.getElementById(
      "wallet-status-unlinked"
    );
    const walletStatusLinked = document.getElementById("wallet-status-linked");
    const walletStatusSiwa = document.getElementById("wallet-status-siwa");
    const walletAddressSiwa = document.getElementById(
      "wallet-address-siwa"
    ) as HTMLSpanElement;

    // Hide all states first
    walletStatusUnlinked?.classList.add("hidden");
    walletStatusLinked?.classList.add("hidden");
    walletStatusSiwa?.classList.add("hidden");

    // Check if user logged in with SIWA (Avalanche wallet)
    const isSiwaLogin =
      auth.authMode === "avalanche" || currentProfile?.login_method === "siwa";

    if (currentProfile?.evm_wallet) {
      if (isSiwaLogin) {
        // SIWA users: show primary identity state (cannot unlink)
        walletStatusSiwa?.classList.remove("hidden");
        if (walletAddressSiwa) {
          walletAddressSiwa.innerText = shortenAddress(
            currentProfile.evm_wallet
          );
        }
      } else {
        // Non-SIWA users: show linked state with unlink option
        walletStatusLinked?.classList.remove("hidden");
        walletAddressDisplay.innerText = shortenAddress(
          currentProfile.evm_wallet
        );
      }
    } else {
      // No wallet linked: show wallet options (only for non-SIWA users)
      if (!isSiwaLogin) {
        walletStatusUnlinked?.classList.remove("hidden");
      }
    }
  }

  async function handleSaveProfile() {
    const auth = getAuthState();
    if (!auth.user || !currentProfile) return;

    const newNickname = nicknameInput.value.trim();
    log.info(COMPONENT_NAME, "Saving profile with nickname:", newNickname);

    if (!newNickname) {
      window.showErrorToast("Nickname cannot be empty");
      return;
    }

    const newEmail = emailInput.value.trim();

    saveBtn.classList.add("loading");
    try {
      await enqueueProfileWrite(auth.user.key, (profile) => ({
        ...profile,
        nickname: newNickname,
        email: newEmail,
      }));

      // Update local state to reflect saved values
      currentProfile.nickname = newNickname;
      currentProfile.email = newEmail;

      window.dispatchEvent(
        new CustomEvent("tresr:profile-updated", {
          detail: {nickname: newNickname},
        })
      );
      // Update the profile store so LoginButton's subscription picks up the new nickname
      profileStore.set({...currentProfile});
      trackProfileUpdate("nickname");
      window.showInfoToast("Profile updated successfully");
      log.info(COMPONENT_NAME, "Profile saved successfully.", currentProfile);
      modal?.close();
    } catch (error) {
      log.error(COMPONENT_NAME, "Failed to save profile:", error);
    } finally {
      saveBtn.classList.remove("loading");
    }
  }

  async function handleLinkWallet() {
    const loadingModal = document.getElementById(
      "wallet-link-loading-modal"
    ) as HTMLDialogElement;
    loadingModal?.showModal();
    try {
      // Unified wallet connection - opens AppKit modal with all options
      const {address} = await connectWallet();
      const walletClient = await getWalletClient();

      const auth = getAuthState();
      if (!auth.user) throw new Error("Not authenticated");

      // Build standardized replay-protected message (ticket #189)
      const message = buildWalletLinkMessage(auth.user.key, address);

      // Verify ownership: sign message
      const sig = await walletClient.signMessage({
        account: address,
        message,
      });

      if (currentProfile) {
        if (auth.user) {
          await enqueueProfileWrite(auth.user.key, (profile) => ({
            ...profile,
            evm_wallet: address,
            verification_signature: sig,
            verification_message: message,
          }));
        }
        // Update local state
        currentProfile.evm_wallet = address;
        currentProfile.verification_signature = sig;
        currentProfile.verification_message = message;
        updateWalletUI();
        trackWalletLink();
        window.showInfoToast("Avalanche Wallet link established");
      }
    } catch (err: unknown) {
      const error = err as {message?: string; code?: number};
      if (
        error.message?.includes("rejected") ||
        error.code === 4001 ||
        error.message?.includes("cancelled")
      ) {
        // User rejected — no error report needed
        window.showWarningToast?.("Wallet connection cancelled or rejected");
      } else if (error.message?.includes("switch") || error.code === 4902) {
        // Network switch needed — clean static message
        log.error(COMPONENT_NAME, "Wrong network — please switch chain", err);
      } else {
        // Unexpected — log.error handles report + clean toast
        log.error(COMPONENT_NAME, "Wallet link failed", err);
      }
    } finally {
      loadingModal?.close();
    }
  }

  async function handleUnlinkWallet() {
    if (!confirm("Remove Avalanche Wallet?")) return;

    try {
      await disconnectWallet();
      if (currentProfile) {
        const auth = getAuthState();
        if (auth.user) {
          await enqueueProfileWrite(auth.user.key, (profile) => ({
            ...profile,
            evm_wallet: undefined,
            wallet_proof: undefined,
          }));
        }
        // Update local state
        currentProfile.evm_wallet = undefined;
        currentProfile.wallet_proof = undefined;
        updateWalletUI();
        trackWalletUnlink();
        window.showInfoToast("Avalanche Wallet link severed");
      }
    } catch (err) {
      log.error(COMPONENT_NAME, "Wallet unlink failed", err);
      window.showErrorToast("Failed to sever Avalanche Wallet link");
    }
  }

  function closeProfileModal() {
    modal?.close();
  }

  saveBtn?.addEventListener("click", handleSaveProfile);
  document
    .getElementById("btn-link-wallet")
    ?.addEventListener("click", handleLinkWallet);
  document
    .getElementById("btn-unlink-wallet")
    ?.addEventListener("click", handleUnlinkWallet);

  document
    .getElementById("btn-close-profile")
    ?.addEventListener("click", closeProfileModal);
  document
    .getElementById("btn-backdrop-close-profile")
    ?.addEventListener("click", closeProfileModal);

  function renderGuestProfile() {
    if (!currentProfile) return;

    nicknameInput.value = currentProfile.nickname || "";
    nicknameInput.disabled = true; // Disable for guests
    emailInput.value = "";
    emailInput.disabled = true;
    principalDisplay.innerText = "Guest Session";

    statHighscore.innerText = currentProfile.stats.high_score.toString();
    statGamesPlayed.innerText =
      currentProfile.stats.total_games_played.toString();
    statGamesWon.innerText = currentProfile.stats.total_games_won.toString();
    statGamesLost.innerText = currentProfile.stats.total_games_lost.toString();

    // Disable wallet linking for guests
    document.getElementById("wallet-status-unlinked")?.classList.add("hidden");
    document.getElementById("wallet-status-linked")?.classList.add("hidden");

    // Disable save button for guests
    saveBtn.disabled = true;

    // Show pre-rendered guest note alert
    document.getElementById("guest-profile-note")?.classList.remove("hidden");
  }

  // --- Avatar ---

  function renderAvatar(profile: UserProfile) {
    const url = profile.preferences?.avatar_url;
    if (url) {
      avatarImg.src = url;
      avatarImg.classList.remove("hidden");
      avatarLetter.classList.add("hidden");
    } else {
      avatarImg.classList.add("hidden");
      avatarLetter.classList.remove("hidden");
      avatarLetter.textContent =
        (profile.nickname || "?")[0]?.toUpperCase() || "?";
    }
  }

  // Click the avatar wrapper → open file picker
  avatarWrapper?.addEventListener("click", () => {
    avatarFileInput?.click();
  });

  // File selected → upload
  avatarFileInput?.addEventListener("change", async () => {
    const file = avatarFileInput.files?.[0];
    if (!file) return;

    const auth = getAuthState();
    if (!auth.user || !currentProfile) return;

    // Show spinner
    avatarUploading?.classList.remove("hidden");

    try {
      const url = await uploadAvatar(file, auth.user.key);

      // Save avatar URL via the write queue to avoid version conflicts
      await enqueueProfileWrite(auth.user.key, (profile) => ({
        ...profile,
        preferences: {
          ...profile.preferences,
          avatar_url: url,
        },
      }));

      // Update local state and display
      currentProfile.preferences = currentProfile.preferences || {
        theme: "synthwave",
        has_read_instructions: false,
      };
      currentProfile.preferences.avatar_url = url;
      renderAvatar(currentProfile);
      profileStore.set({...currentProfile});
      trackAvatarUpload();
      window.showInfoToast("Avatar updated!");
      log.info(COMPONENT_NAME, "Avatar uploaded successfully:", url);
    } catch (err) {
      log.error(COMPONENT_NAME, "Avatar upload failed:", err);
      window.showErrorToast("Avatar upload failed");
    } finally {
      avatarUploading?.classList.add("hidden");
      // Reset input so the same file can be re-selected
      avatarFileInput.value = "";
    }
  });

  // Listen for custom event instead of window global (ticket #263)
  function handleOpenProfile() {
    openProfileModal();
  }
  document.addEventListener("tresr:open-profile", handleOpenProfile);

  // Cleanup document-level listener on navigation (ticket #241)
  document.addEventListener(
    "astro:before-preparation",
    () => {
      document.removeEventListener("tresr:open-profile", handleOpenProfile);
    },
    {once: true}
  );
</script>
