---
import {config} from "@/lib/config/client";

interface Props {
  minTime?: number;
  id?: string;
}

const {minTime = 1500, id = "loader"} = Astro.props;

// Pass the full array to the client — randomization happens at runtime, not build time
const messages = config.app.loader_messages;
---

<div
  id={id}
  class="fixed inset-0 z-[100] flex flex-col items-center justify-center bg-black transition-opacity duration-700"
>
  <div class="text-center">
    <span class="loading loading-bars loading-lg text-primary"></span>
    <p
      id={`${id}-message`}
      class="text-primary font-display mt-4 animate-pulse tracking-widest uppercase"
    >
      Loading...
    </p>
  </div>
</div>

<script is:inline define:vars={{id, minTime, messages}}>
  // Pick a random message on each page load (not at build time)
  const msgEl = document.getElementById(id + "-message");
  if (msgEl && messages.length > 0) {
    msgEl.textContent = messages[Math.floor(Math.random() * messages.length)];
  }

  document.addEventListener("DOMContentLoaded", () => {
    const start = window.startTime || Date.now();
    const elapsed = Date.now() - start;
    const remaining = Math.max(0, minTime - elapsed);

    setTimeout(() => {
      const loader = document.getElementById(id);
      if (loader) {
        loader.classList.add("opacity-0");
        setTimeout(() => {
          loader.classList.add("hidden");
          // Dispatch event so other components know loading is done
          window.dispatchEvent(new CustomEvent("loader-ready"));
        }, 700); // Match transition duration
      }
    }, remaining);
  });
</script>
