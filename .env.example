# Juno Satellite Configuration

# Local Internet Identity Canister ID (Default for Juno Emulator is rdmx6-jaaaa-aaaaa-aaadq-cai)
VITE_INTERNET_IDENTITY_ID=rdmx6-jaaaa-aaaaa-aaadq-cai

# Define your Satellite and Orbiter ID for Development
VITE_DEVELOPMENT_SATELLITE_ID=your_satellite_id_here_development
VITE_DEVELOPMENT_ORBITER_ID=your_orbiter_id_here_development

# Define your Satellite and Orbiter ID for Staging
VITE_STAGING_SATELLITE_ID=your_satellite_id_here_staging
VITE_STAGING_ORBITER_ID=your_orbiter_id_here_staging

# Define your Satellite and Orbiter ID for Production
VITE_PRODUCTION_SATELLITE_ID=your-satellite_id_here_production
VITE_PRODUCTION_ORBITER_ID=your-your_orbiter_id_here_production

# SvelteKit Site URL (Final deployed URL)
VITE_SITE_URL=https://myapp.mydomain.com

# IC SIWA Canister ID (Sign In With Avalanche)
# Managed externally - obtain from ic-siwa project
VITE_SIWA_PROVIDER_ID=canister-id-goes-here

# NOTES:
#   For Development,
#     Any changes to the Satellite ID require a 'direnv reload' to apply.
#     You can get the ID from http://localhost:5866
#   For Production,
#     Set VITE_X_SATELLITE_ID to your production satellite ID in CI.
#     You can get the ID from https://console.juno.build
