---
import {JUNO_ENVIRONMENT} from "@/lib/config/constants";

const isProduction = JUNO_ENVIRONMENT === "production";
---

{
  !isProduction && (
    <button
      id="faucet-btn"
      class="btn btn-ghost btn-circle hidden text-xl"
      title="Claim test tokens"
    >
      🚰
    </button>
  )
}

<script>
  import {subscribeToAuth} from "@/lib/auth";
  import {
    subscribeToConnection,
    getConnectedAddress,
  } from "@/lib/wallet/connection";
  import {
    claimFaucet,
    getFaucetCooldownStatus,
    getFaucetDripAmount,
    isFaucetDeployed,
  } from "@/lib/blockchain/faucet";
  import {clearCachedBalance, formatBalance} from "@/lib/blockchain/balance";
  import {config} from "@/lib/config/client";
  import {log} from "@/lib/utils/log";
  import {trackFaucetClaim, trackError} from "@/lib/metrics/analytics";

  const COMPONENT_NAME = "FaucetButton";

  const btn = document.getElementById("faucet-btn") as HTMLButtonElement | null;
  if (btn) {
    let disposed = false;
    let walletConnected = false;
    let isAuthenticatedNonGuest = false;
    let isProcessing = false;
    let cooldownRemaining = 0;
    let cooldownInterval: ReturnType<typeof setInterval> | null = null;

    const EMOJI_CONTENT = "\u{1F6B0}"; // 🚰

    function setSpinner() {
      btn!.textContent = "";
      const spinner = document.createElement("span");
      spinner.className = "loading loading-spinner loading-sm";
      btn!.appendChild(spinner);
      btn!.disabled = true;
    }

    function resetButton() {
      btn!.textContent = EMOJI_CONTENT;
      btn!.disabled = false;
    }

    function setCooldownState(seconds: number) {
      cooldownRemaining = seconds;
      if (seconds <= 0) {
        resetButton();
        btn!.title = "Claim test tokens";
        stopCooldownTick();
        return;
      }
      btn!.textContent = EMOJI_CONTENT;
      btn!.disabled = true;
      btn!.title = `Cooldown: ${formatCooldownTime(seconds)}`;
      startCooldownTick();
    }

    function formatCooldownTime(seconds: number): string {
      const m = Math.floor(seconds / 60);
      const s = seconds % 60;
      return m > 0 ? `${m}m ${s}s` : `${s}s`;
    }

    function startCooldownTick() {
      stopCooldownTick();
      if (cooldownRemaining <= 0) return;
      cooldownInterval = setInterval(() => {
        if (disposed) {
          stopCooldownTick();
          return;
        }
        cooldownRemaining = Math.max(0, cooldownRemaining - 1);
        if (cooldownRemaining <= 0) {
          resetButton();
          btn!.title = "Claim test tokens";
          stopCooldownTick();
        } else {
          btn!.title = `Cooldown: ${formatCooldownTime(cooldownRemaining)}`;
        }
      }, 1_000);
    }

    function stopCooldownTick() {
      if (cooldownInterval) {
        clearInterval(cooldownInterval);
        cooldownInterval = null;
      }
    }

    function evaluateVisibility() {
      if (!btn) return;
      if (isAuthenticatedNonGuest && isFaucetDeployed(config)) {
        btn.classList.remove("hidden");
      } else {
        btn.classList.add("hidden");
      }
    }

    async function handleClick() {
      if (isProcessing || disposed || btn!.disabled) return;

      if (!walletConnected) {
        window.showWarningToast?.("Connect your wallet first 🔗");
        return;
      }

      const address = getConnectedAddress();
      if (!address) {
        log.warn(COMPONENT_NAME, "No wallet address found");
        return;
      }

      // Lock immediately — before any await — to prevent double-submit.
      // A second click arriving during the async cooldown check would otherwise
      // pass the isProcessing guard and send the same nonce twice ("already imported").
      isProcessing = true;
      setSpinner();

      // Check cooldown before attempting
      try {
        const status = await getFaucetCooldownStatus(address);
        if (disposed) return;
        if (!status.canClaim) {
          log.warn(
            COMPONENT_NAME,
            `Faucet on cooldown: ${formatCooldownTime(status.remainingSeconds)}`
          );
          setCooldownState(status.remainingSeconds);
          isProcessing = false;
          return;
        }
      } catch (err) {
        log.error(COMPONENT_NAME, "Failed to check cooldown", err);
        isProcessing = false;
        resetButton();
        return;
      }

      try {
        await claimFaucet();

        // Read drip amount for the toast
        let amountDisplay = "tokens";
        try {
          const dripAmount = await getFaucetDripAmount();
          const env = (
            await import("@/lib/blockchain/networks/chain")
          ).getEnvironmentKey();
          const ticker = config.blockchain.avalanche[env].token_ticker;
          amountDisplay = `${formatBalance(dripAmount)} $${ticker}`;
        } catch {
          // Non-critical — just show generic message
        }

        trackFaucetClaim(amountDisplay);
        window.showInfoToast?.(`Claimed ${amountDisplay}!`);

        // Clear cached balance so next check is fresh
        clearCachedBalance(address);

        // Signal balance refresh to other components
        document.dispatchEvent(new CustomEvent("tresr:balance-refresh"));

        // Start cooldown after successful claim
        try {
          const status = await getFaucetCooldownStatus(address);
          if (disposed) return;
          if (!status.canClaim) {
            setCooldownState(status.remainingSeconds);
          }
        } catch {
          // Non-critical
        }
      } catch (err) {
        const message = err instanceof Error ? err.message : String(err);

        // Detect voluntary user rejection before logging/tracking — cancellations
        // are expected UX, not errors we want reported to analytics.
        const isUserRejection =
          message.includes("User rejected") ||
          message.includes("user rejected") ||
          message.includes("User denied") ||
          message.includes("rejected the request");

        const isReconnecting = message.includes(
          "unavailable while reconnecting"
        );

        if (!isUserRejection) {
          log.error(COMPONENT_NAME, "Faucet claim failed", err);
        }
        if (!isUserRejection && !isReconnecting) {
          trackError("faucet_claim", message);
        }

        // Show a friendly toast based on the revert reason
        if (isUserRejection) {
          // User explicitly cancelled — just a polite notice.
          window.showInfoToast?.("Transaction cancelled ✋");
        } else if (isReconnecting) {
          // Wallet connector is still initialising after a page reload or
          // idle reconnect. Ask the user to try again in a moment.
          window.showWarningToast?.(
            "Wallet is reconnecting — please try again in a moment 🔄"
          );
        } else if (message.includes("Balance too high")) {
          let tickerSuffix = "tokens";
          try {
            const env = (
              await import("@/lib/blockchain/networks/chain")
            ).getEnvironmentKey();
            const ticker = config.blockchain.avalanche[env].token_ticker;
            tickerSuffix = `$${ticker} tokens`;
          } catch {
            // Non-critical — show generic label
          }
          window.showWarningToast?.(
            `Sorry degen, you already have too many ${tickerSuffix} 🤑`
          );
        } else if (message.includes("Cooldown active")) {
          window.showWarningToast?.("Hold up — faucet is on cooldown ⏳");
        } else if (message.includes("Faucet empty")) {
          window.showWarningToast?.("Faucet is dry — no tokens left 🏜️");
        } else if (message.includes("not broadcast to the network")) {
          // Wallet returned a ghost hash but never sent the tx — surface a clear
          // actionable message instead of a generic error ID.
          window.showWarningToast?.(
            "Transaction not sent — check your wallet activity and try again 🔄"
          );
        } else if (
          message.includes("already imported") ||
          message.includes("nonce too low") ||
          message.includes("replacement transaction underpriced")
        ) {
          // Stale tx replay — MetaMask replayed an old signed tx with the same nonce.
          // Tell the user to reset their wallet activity and retry.
          window.showWarningToast?.(
            "Duplicate transaction detected — reset your wallet activity and try again 🔄"
          );
        } else {
          // log.error() already calls reportError and shows showErrorToast with
          // the error_id internally — no manual reportError/showErrorToast needed here.
        }
      } finally {
        isProcessing = false;
        if (cooldownRemaining <= 0) {
          resetButton();
        }
      }
    }

    btn.addEventListener("click", handleClick);

    // Check initial cooldown when wallet connects
    async function checkInitialCooldown() {
      if (!walletConnected || disposed) return;
      const address = getConnectedAddress();
      if (!address) return;
      try {
        const status = await getFaucetCooldownStatus(address);
        if (disposed) return;
        if (!status.canClaim) {
          setCooldownState(status.remainingSeconds);
        }
      } catch {
        // Silently fail — cooldown check is a nice-to-have
      }
    }

    let unsubWallet: (() => void) | null = null;

    const unsubAuth = subscribeToAuth((state) => {
      isAuthenticatedNonGuest = state.isAuthenticated && !state.isGuest;

      if (isAuthenticatedNonGuest && !unsubWallet) {
        unsubWallet = subscribeToConnection((connected) => {
          walletConnected = connected;
          // Disable the button while the wallet store is still reconnecting
          // so the user gets feedback instead of a silent "Connect wallet first" warn.
          if (btn && cooldownRemaining <= 0 && !isProcessing) {
            btn.disabled = !connected;
            btn.title = connected ? "Claim test tokens" : "Connecting wallet…";
          }
          evaluateVisibility();
          if (connected) checkInitialCooldown();
        });
      } else if (!isAuthenticatedNonGuest && unsubWallet) {
        unsubWallet();
        unsubWallet = null;
        walletConnected = false;
      }

      evaluateVisibility();
    });

    // Cleanup on navigation
    document.addEventListener(
      "astro:before-preparation",
      () => {
        disposed = true;
        stopCooldownTick();
        unsubAuth();
        if (unsubWallet) unsubWallet();
        btn.removeEventListener("click", handleClick);
      },
      {once: true}
    );
  }
</script>

<style>
  #faucet-btn:disabled {
    pointer-events: auto;
    cursor: not-allowed;
  }
</style>
