---

---

<dialog id="modal-critical-error" class="modal modal-middle">
  <div
    class="modal-box border-error/30 bg-base-300 flex h-full max-h-full w-full max-w-full flex-col items-center justify-center border p-4 text-center sm:h-auto sm:max-h-[85vh] sm:w-auto sm:max-w-lg sm:rounded-2xl sm:p-6"
  >
    <h3
      class="text-error font-display text-2xl font-black tracking-widest uppercase sm:text-4xl"
    >
      Critical Error
    </h3>

    <div role="alert" class="alert alert-error my-4 text-left">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-6 w-6 shrink-0 stroke-current"
        fill="none"
        viewBox="0 0 24 24"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z"
        ></path>
      </svg>
      <p id="critical-error-message" class="text-sm sm:text-base">
        An unexpected error occurred.
      </p>
    </div>

    <p class="py-1 text-xs italic opacity-50 sm:py-2 sm:text-sm">
      The game has been stopped. Check the browser console for additional
      details.
    </p>

    <div class="modal-action w-full flex-col gap-1 sm:gap-2">
      <button
        onclick="window.location.href='/'"
        class="btn btn-error btn-block btn-sm sm:btn-md">Return to Base</button
      >
    </div>
  </div>
</dialog>

<script>
  import {gameState} from "@/lib/game/state";
  import {log} from "@/lib/utils/log";
  import {trackError} from "@/lib/metrics/analytics";

  const modal = document.getElementById(
    "modal-critical-error"
  ) as HTMLDialogElement;
  const messageEl = document.getElementById("critical-error-message");

  function showCriticalError(message: string) {
    log.error("CriticalError", message);
    if (messageEl) messageEl.textContent = message;
    if (modal && !modal.open) modal.showModal();

    // Fire analytics event (fire-and-forget)
    trackError("critical_error", message, {severity: "critical"}).catch(() => {
      // Best-effort — analytics may not be initialized
    });

    // Attempt to stop the Phaser game loop
    const game = (window as any).__phaserGame;
    if (game) {
      try {
        game.destroy(true);
        delete (window as any).__phaserGame;
      } catch {
        // Best-effort — game may already be in a bad state
      }
    }
  }

  // Listen for CustomEvent dispatches (from game code or anywhere)
  function handleCriticalEvent(e: Event) {
    const message =
      (e as CustomEvent<string>).detail || "An unexpected error occurred.";
    showCriticalError(message);
  }
  document.addEventListener("tresr:critical-error", handleCriticalEvent);

  // Also subscribe to state changes
  const unsub = gameState.subscribe((state) => {
    if (state.criticalError && !modal.open) {
      showCriticalError(state.criticalError);
    }
  });

  // Expose test helper on window for dev console testing
  (window as any).triggerCriticalError = (msg?: string) => {
    showCriticalError(msg || "Test critical error from console");
  };

  document.addEventListener(
    "astro:before-preparation",
    () => {
      unsub();
      document.removeEventListener("tresr:critical-error", handleCriticalEvent);
      delete (window as any).triggerCriticalError;
    },
    {once: true}
  );
</script>
