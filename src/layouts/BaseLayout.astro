---
import Header from "@/components/user/Header.astro";
import ProfileModal from "@/components/user/ProfileModal.astro";
import UpdatePrompt from "@/components/pwa/UpdatePrompt.astro";
import NotificationToast from "@/components/notifications/NotificationToast.astro";
import Confetti from "@/components/effects/Confetti.astro";

interface Props {
  title: string;
  description?: string;
}

const {title, description = "A 2.5D platformer for the Tresr Community"} =
  Astro.props;
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta
      name="viewport"
      content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no,viewport-fit=cover"
    />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#1a1025" />
    <link rel="icon" type="image/png" href="/assets/icons/ios/32.png" />
    <link rel="manifest" href="/manifest.json" />
    <script is:inline>
      window.startTime = Date.now();
      // Apply saved theme immediately to prevent flash of wrong theme colors
      (function () {
        var t = localStorage.getItem("theme");
        if (t) document.documentElement.setAttribute("data-theme", t);
      })();
    </script>
    <title>{title}</title>
  </head>
  <body
    class="bg-base-300 min-h-screen overflow-x-hidden"
    style="touch-action:manipulation"
  >
    <Header />
    <main>
      <slot />
    </main>

    <!-- Portrait orientation blocker — global across all pages -->
    <div
      id="portrait-warning"
      class="fixed inset-0 z-[99999] hidden flex-col items-center justify-center gap-6 bg-black text-center"
    >
      <div class="animate-bounce text-7xl">📱</div>
      <p class="font-display text-primary text-3xl font-bold tracking-wide">
        ROTATE YOUR DEVICE
      </p>
      <p class="max-w-xs text-lg opacity-60">
        This game is best played in landscape mode.
      </p>
      <div class="mt-4 animate-pulse text-5xl">↻</div>
    </div>
    <script is:inline>
      // Portrait detection — runs immediately, no module loading needed.
      // Uses both matchMedia AND dimension check for reliability across all devices.
      // Debounced + deduplicated: only fires tresr:portrait-change when state actually changes.
      (function () {
        var warning = document.getElementById("portrait-warning");
        if (!warning) return;

        var lastPortrait = null; // null = not yet determined
        var debounceTimer = null;

        function isTouchDevice() {
          return "ontouchstart" in window || navigator.maxTouchPoints > 0;
        }

        function isPortrait() {
          // Only block portrait on touch devices (phones/tablets)
          if (!isTouchDevice()) return false;
          // Primary check: dimensions (most reliable)
          if (window.innerHeight > window.innerWidth) return true;
          // Fallback: media query
          if (
            window.matchMedia &&
            window.matchMedia("(orientation: portrait)").matches
          )
            return true;
          return false;
        }

        function applyPortrait(portrait) {
          // Deduplicate: skip if state hasn't changed
          if (portrait === lastPortrait) return;
          lastPortrait = portrait;

          if (portrait) {
            warning.classList.remove("hidden");
            warning.classList.add("flex");
          } else {
            warning.classList.add("hidden");
            warning.classList.remove("flex");
          }
          document.dispatchEvent(
            new CustomEvent("tresr:portrait-change", {detail: {portrait}})
          );
        }

        function check() {
          applyPortrait(isPortrait());
        }

        // Debounced resize handler — coalesces rapid resize events into one call
        function debouncedCheck() {
          if (debounceTimer !== null) clearTimeout(debounceTimer);
          debounceTimer = setTimeout(check, 150);
        }

        // Check immediately on load (no debounce needed for initial state)
        check();
        window.addEventListener("resize", debouncedCheck);
        window.addEventListener("orientationchange", function () {
          // Delay slightly — some browsers update dimensions after the event
          setTimeout(check, 100);
        });
      })();
    </script>

    <UpdatePrompt />
    <NotificationToast />
    <ProfileModal />
    <Confetti />
    <script>
      import PWA from "@/lib/pwa";
      import {initAnalytics, trackPageView} from "@/lib/metrics/analytics";

      // Register PWA on load
      document.addEventListener("DOMContentLoaded", () => {
        PWA.getInstance().register();

        // Defer analytics init to avoid blocking INP
        const initAndTrack = async () => {
          await initAnalytics();
          await trackPageView(window.location.pathname);
        };
        if ("requestIdleCallback" in window) {
          requestIdleCallback(() => initAndTrack());
        } else {
          setTimeout(() => initAndTrack(), 0);
        }
      });

      // Clean up periodic timers when the page is unloaded
      window.addEventListener("pagehide", () => {
        PWA.getInstance().destroy();
      });
    </script>
  </body>
</html>

<style is:global>
  @import "../styles/global.css";

  /* Orbitron for headings - cyberpunk style */
  h1,
  h2,
  h3,
  .font-display {
    font-family: "Orbitron", sans-serif;
  }
</style>
