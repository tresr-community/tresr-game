---
// ClaimsList.astro — Displays pending rewards and claim history
---

<div id="claims-container" class="space-y-6">
  <!-- Tabs -->
  <div class="tabs tabs-boxed bg-base-300 mx-auto mb-8 w-fit p-1">
    <a id="tab-pending" class="tab tab-active px-8 font-bold"
      >Pending Claims (<span id="pending-count">0</span>)</a
    >
    <a id="tab-history" class="tab px-8 font-bold">History</a>
  </div>

  <!-- Loading State -->
  <div id="claims-loading" class="flex justify-center p-12">
    <span class="loading loading-spinner text-warning loading-lg"></span>
  </div>

  <!-- Pending Claims View -->
  <div id="view-pending" class="hidden space-y-4">
    <div id="pending-empty" class="hidden py-12 text-center">
      <div class="mb-4 text-5xl">🌪️</div>
      <h3 class="text-base-content/70 text-xl font-bold">No pending claims</h3>
      <p class="text-base-content/50">Play games to earn on-chain rewards.</p>
    </div>
    <div id="pending-list" class="grid gap-4 md:grid-cols-2">
      <!-- Injected pending cards -->
    </div>
  </div>

  <!-- History View -->
  <div id="view-history" class="hidden space-y-4">
    <div id="history-empty" class="hidden py-12 text-center">
      <div class="mb-4 text-5xl">📜</div>
      <h3 class="text-base-content/70 text-xl font-bold">No history yet</h3>
      <p class="text-base-content/50">Your claimed rewards will appear here.</p>
    </div>
    <div
      class="bg-base-100 rounded-box border-base-300 hidden overflow-x-auto border shadow-sm"
      id="history-table-container"
    >
      <table class="table-zebra table-sm md:table-md table w-full">
        <thead>
          <tr class="bg-base-200">
            <th>Date</th>
            <th>Type</th>
            <th>Amount</th>
            <th>Status</th>
            <th>Tx</th>
          </tr>
        </thead>
        <tbody id="history-list">
          <!-- Injected history rows -->
        </tbody>
      </table>
    </div>
  </div>
</div>

<script>
  import {listDocs, setDoc} from "@junobuild/core";
  import type {Doc} from "@junobuild/core";
  import {initAuth, subscribeToAuth} from "@/lib/auth";
  import {getConnectedAddress, getWalletClient} from "@/lib/wallet/connection";
  import {VaultAbi} from "@/lib/blockchain/abi/vault";
  import {config} from "@/lib/config/client";
  import {getEnvironmentKey} from "@/lib/blockchain/networks/chain";
  import {log} from "@/lib/utils/log";

  const COMPONENT_NAME = "ClaimsList";

  // Elements
  const tabPending = document.getElementById("tab-pending")!;
  const tabHistory = document.getElementById("tab-history")!;
  const viewPending = document.getElementById("view-pending")!;
  const viewHistory = document.getElementById("view-history")!;
  const claimsLoading = document.getElementById("claims-loading")!;
  const pendingList = document.getElementById("pending-list")!;
  const pendingEmpty = document.getElementById("pending-empty")!;
  const historyList = document.getElementById("history-list")!;
  const historyEmpty = document.getElementById("history-empty")!;
  const historyTableContainer = document.getElementById(
    "history-table-container"
  )!;
  const pendingCountLabel = document.getElementById("pending-count")!;

  let currentTab: "pending" | "history" = "pending";
  let currentUser: any = null;
  let allClaims: Doc<any>[] = [];

  // Config
  const env = getEnvironmentKey();
  const explorerUrl = config.blockchain.avalanche[env].explorer_url;
  const vaultAddress = config.blockchain.avalanche[env].vault_contract;

  // Tabs logic
  tabPending.addEventListener("click", () => switchTab("pending"));
  tabHistory.addEventListener("click", () => switchTab("history"));

  function switchTab(tab: "pending" | "history") {
    currentTab = tab;
    if (tab === "pending") {
      tabPending.classList.add("tab-active");
      tabHistory.classList.remove("tab-active");
      viewPending.classList.remove("hidden");
      viewHistory.classList.add("hidden");
    } else {
      tabHistory.classList.add("tab-active");
      tabPending.classList.remove("tab-active");
      viewHistory.classList.remove("hidden");
      viewPending.classList.add("hidden");
    }
  }

  // Await initAuth before subscribing — subscribeToAuth fires immediately with
  // the current state, but listDocs requires initSatellite() to have run first.
  // Without this guard, a returning SIWA user gets "No satellite ID defined"
  // on the claims page because the subscription fires before Juno is ready.
  initAuth().then(() => {
    subscribeToAuth(async (user) => {
      currentUser = user;
      if (user && !user.isGuest) {
        await fetchClaims();
      } else {
        claimsLoading.classList.add("hidden");
        viewPending.classList.remove("hidden");
        viewHistory.classList.remove("hidden");
        pendingEmpty.classList.remove("hidden");
        historyEmpty.classList.remove("hidden");
      }
    });
  });

  async function fetchClaims() {
    if (!currentUser) return;
    try {
      claimsLoading.classList.remove("hidden");
      viewPending.classList.add("hidden");
      viewHistory.classList.add("hidden");

      // List all docs in the claims collection for this owner
      const {items} = await listDocs({
        collection: "claims",
        filter: {
          owner: currentUser.key,
        },
      });

      // Sort newest first based on updated_at
      allClaims = items.sort(
        (a, b) => Number(b.updated_at) - Number(a.updated_at)
      );

      renderClaims();
    } catch (err: unknown) {
      log.warn(COMPONENT_NAME, "Failed to fetch claims", err);
      allClaims = [];
      renderClaims();
    } finally {
      claimsLoading.classList.add("hidden");
      switchTab(currentTab);
    }
  }

  function renderClaims() {
    const pending = allClaims.filter((c) => c.data.status === "readyforchain");
    const historic = allClaims.filter(
      (c) => c.data.status === "completed" || c.data.status === "failed"
    );

    pendingCountLabel.textContent = pending.length.toString();

    // Render Pending
    pendingList.innerHTML = "";
    if (pending.length === 0) {
      pendingEmpty.classList.remove("hidden");
    } else {
      pendingEmpty.classList.add("hidden");
      pending.forEach((claim) => {
        const card = document.createElement("div");
        card.className =
          "card bg-base-100 shadow-lg border border-warning/30 hover:border-warning/60 transition-colors";

        const isConsolation = claim.data.claim_type === "consolation";
        const title = isConsolation ? "Consolation Prize" : "Boss Defeated!";
        const amountDisplay = (claim.data.amount / 1e18).toFixed(2);

        card.innerHTML = `
          <div class="card-body p-5">
            <h2 class="card-title text-warning">${title}</h2>
            <div class="flex justify-between items-end mt-2">
              <div>
                <p class="text-sm text-base-content/60">Reward amount:</p>
                <p class="text-3xl font-mono font-bold">${amountDisplay} <span class="text-sm">$TRESR</span></p>
              </div>
              <button class="btn btn-warning btn-sm claim-btn" data-id="${claim.key}">
                Claim Now
              </button>
            </div>
          </div>
        `;
        pendingList.appendChild(card);
      });

      // Attach button listeners
      document.querySelectorAll(".claim-btn").forEach((btn) => {
        btn.addEventListener("click", handleClaim);
      });
    }

    // Render History
    historyList.innerHTML = "";
    if (historic.length === 0) {
      historyEmpty.classList.remove("hidden");
      historyTableContainer.classList.add("hidden");
    } else {
      historyEmpty.classList.add("hidden");
      historyTableContainer.classList.remove("hidden");
      historic.forEach((claim) => {
        const tr = document.createElement("tr");
        const date = new Date(
          Number(claim.updated_at) / 1000000
        ).toLocaleDateString();
        const type =
          claim.data.claim_type === "consolation" ? "Consolation" : "Boss Win";
        const amountDisplay = (claim.data.amount / 1e18).toFixed(2);
        const statusBadge =
          claim.data.status === "completed"
            ? '<span class="badge badge-success badge-sm">Success</span>'
            : '<span class="badge badge-error badge-sm">Failed</span>';

        const txLink = claim.data.tx_hash
          ? `<a href="${explorerUrl}${claim.data.tx_hash}" target="_blank" class="link link-primary font-mono text-xs">View</a>`
          : "-";

        tr.innerHTML = `
          <td class="whitespace-nowrap">${date}</td>
          <td>${type}</td>
          <td class="font-mono">${amountDisplay}</td>
          <td>${statusBadge}</td>
          <td>${txLink}</td>
        `;
        historyList.appendChild(tr);
      });
    }
  }

  async function handleClaim(e: Event) {
    const btn = e.currentTarget as HTMLButtonElement;
    const claimId = btn.getAttribute("data-id");
    if (!claimId) return;

    const claimDoc = allClaims.find((c) => c.key === claimId);
    if (!claimDoc) return;

    if (!claimDoc.data.signature) {
      alert("Missing signature. Try again later.");
      return;
    }

    // Connect wallet if needed
    const address = getConnectedAddress();
    if (!address) {
      alert("Please connect your wallet first!");
      return;
    }

    try {
      btn.innerHTML =
        '<span class="loading loading-spinner"></span> Claiming...';
      btn.disabled = true;

      const client = await getWalletClient();

      // Formatting bytes32 session id
      const formattedSessionId = claimDoc.data.game_session_id
        .padEnd(66, "0")
        .slice(0, 66); // Simple padding for bytes32 if it's a UUID hex

      log.info(COMPONENT_NAME, "Sending claim tx...");
      const txHash = await client.writeContract({
        address: vaultAddress as any,
        abi: VaultAbi,
        functionName: "claim",
        chain: null,
        account: address as any,
        args: [
          formattedSessionId as any,
          BigInt(claimDoc.data.amount.toString()),
          BigInt(claimDoc.data.keys_collected.toString()),
          claimDoc.data.signature as any,
        ],
      });

      log.info(COMPONENT_NAME, `Tx Hash: ${txHash}`);

      // Update document immediately to processing
      claimDoc.data.status = "processing";
      claimDoc.data.tx_hash = txHash;
      await setDoc({
        collection: "claims",
        doc: claimDoc,
      });

      // Fire global confetti event
      document.dispatchEvent(
        new CustomEvent("tresr:confetti", {
          detail: {count: 120, colors: ["#facc15", "#f59e0b", "#fbbf24"]},
        })
      );

      // Reload claims list
      setTimeout(fetchClaims, 3000);
    } catch (err: any) {
      log.error(COMPONENT_NAME, "Claim tx failed", err);
      alert(`Claim failed: ${err.shortMessage || err.message}`);
      btn.innerHTML = "Claim Now";
      btn.disabled = false;
    }
  }
</script>
