{
  "name": "tresr-game",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "juno-dev loop",
    "start": "juno-dev start",
    "version-bump": "bun run bin/version.ts --bump",
    "version-set": "bun run bin/version.ts --set",
    "version-get": "bun run bin/version.ts --get",
    "version-reset": "bun run bin/version.ts --reset",
    "client-config": "bun run bin/client-config.ts",
    "prebuild": "bun run client-config",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "astro check && eslint .",
    "format": "prettier --write './**/*.{ts,js,mjs,json,css,astro,html,md}'",
    "audio": "bun run bin/audio.ts",
    "sprites": "bun run bin/sprites.ts",
    "wallpapers": "bun run bin/wallpapers.ts",
    "videos": "bun run bin/videos.ts",
    "postinstall:copy-auth": "bun -e \"require('node:fs').cpSync('node_modules/@junobuild/core/dist/workers/', './public/workers', {recursive: true});\"",
    "postinstall": "bun run postinstall:copy-auth"
  },
  "dependencies": {
    "@astrojs/check": "0.9.6",
    "@astrojs/sitemap": "3.7.0",
    "@dfinity/agent": "3.4.3",
    "@dfinity/auth-client": "3.4.3",
    "@dfinity/candid": "3.4.3",
    "@dfinity/identity": "3.4.3",
    "@dfinity/principal": "3.4.3",
    "@junobuild/analytics": "0.2.11",
    "@junobuild/cli": "0.13.13",
    "@junobuild/core": "5.2.0",
    "@reown/appkit": "1.8.18",
    "@reown/appkit-adapter-wagmi": "1.8.18",
    "@tanstack/query-core": "5.90.20",
    "@types/seedrandom": "3.0.8",
    "@wagmi/core": "3.4.0",
    "astro": "5.17.3",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "ic-siwa": "0.2.5",
    "js-yaml": "4.1.1",
    "nanostores": "1.1.0",
    "phaser": "3.90.0",
    "rehype-stringify": "10.0.1",
    "remark-breaks": "4.0.0",
    "remark-emoji": "5.0.2",
    "remark-gfm": "4.0.1",
    "remark-parse": "11.0.0",
    "remark-rehype": "11.1.2",
    "seedrandom": "3.0.5",
    "sharp": "0.34.5",
    "simple-cbor": "0.4.1",
    "tailwind-merge": "3.5.0",
    "unified": "11.0.5",
    "viem": "2.46.2",
    "yaml": "2.8.2"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@icp-sdk/bindgen": "0.2.2",
    "@junobuild/config": "2.11.0",
    "@junobuild/vite-plugin": "4.7.0",
    "@tailwindcss/postcss": "4.2.1",
    "@tailwindcss/vite": "4.2.0",
    "@types/js-yaml": "4.0.9",
    "bun-types": "1.3.9",
    "daisyui": "5.5.19",
    "daisyui-blueprint": "1.2.1",
    "eslint": "10.0.1",
    "globals": "17.3.0",
    "postcss": "8.5.6",
    "prettier": "3.8.1",
    "prettier-plugin-astro": "0.14.1",
    "prettier-plugin-tailwindcss": "0.7.2",
    "tailwindcss": "4.2.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.56.0",
    "vite": "7.3.1"
  }
}
