{
  "name": "tresr-game",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "juno-dev loop",
    "start": "juno-dev start",
    "version-bump": "bun run bin/version.ts --bump",
    "version-set": "bun run bin/version.ts --set",
    "version-get": "bun run bin/version.ts --get",
    "version-reset": "bun run bin/version.ts --reset",
    "client-config": "bun run bin/client-config.ts",
    "prebuild": "svelte-kit sync && bun run client-config",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "svelte-kit sync && svelte-check && eslint .",
    "format": "prettier --write './**/*.{ts,js,mjs,json,css,svelte,html,md}'",
    "audio": "bun run bin/audio.ts",
    "sprites": "bun run bin/sprites.ts",
    "wallpapers": "bun run bin/wallpapers.ts",
    "videos": "bun run bin/videos.ts",
    "test": "bun test ./bin/config-schema.test.ts",
    "test:config": "bun test ./bin/config-schema.test.ts",
    "postinstall:copy-auth": "bun -e \"require('node:fs').cpSync('node_modules/@junobuild/core/dist/workers/', './static/workers', {recursive: true});\"",
    "postinstall": "bun run postinstall:copy-auth"
  },
  "dependencies": {
    "@dfinity/agent": "3.4.3",
    "@dfinity/auth-client": "3.4.3",
    "@dfinity/candid": "3.4.3",
    "@dfinity/identity": "3.4.3",
    "@dfinity/principal": "3.4.3",
    "@junobuild/analytics": "0.2.12",
    "@junobuild/core": "5.2.2",
    "@reown/appkit": "1.8.19",
    "@reown/appkit-adapter-wagmi": "1.8.19",
    "@tanstack/query-core": "5.90.20",
    "@types/seedrandom": "3.0.8",
    "@wagmi/core": "3.4.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "ic-siwa": "0.2.5",
    "js-yaml": "4.1.1",
    "nanostores": "1.2.0",
    "phaser": "3.90.0",
    "rehype-stringify": "10.0.1",
    "remark-breaks": "4.0.0",
    "remark-emoji": "5.0.2",
    "remark-gfm": "4.0.1",
    "remark-parse": "11.0.0",
    "remark-rehype": "11.1.2",
    "seedrandom": "3.0.5",
    "sharp": "0.34.5",
    "simple-cbor": "0.4.1",
    "tailwind-merge": "3.5.0",
    "unified": "11.0.5",
    "viem": "2.47.4",
    "yaml": "2.8.2"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@icp-sdk/bindgen": "0.2.3",
    "@junobuild/cli": "0.14.2",
    "@junobuild/config": "2.15.0",
    "@junobuild/vite-plugin": "4.7.1",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.55.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/postcss": "4.2.1",
    "@tailwindcss/typography": "0.5.19",
    "@tailwindcss/vite": "4.2.1",
    "@types/js-yaml": "4.0.9",
    "bun-types": "1.3.10",
    "daisyui": "5.5.19",
    "daisyui-blueprint": "1.2.1",
    "eslint": "10.0.3",
    "globals": "17.4.0",
    "postcss": "8.5.8",
    "prettier": "3.8.1",
    "prettier-plugin-svelte": "^3.5.1",
    "prettier-plugin-tailwindcss": "0.7.2",
    "svelte": "^5.54.0",
    "svelte-check": "^4.4.5",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.57.1",
    "vite": "7.3.1",
    "zod": "4.3.6"
  }
}
