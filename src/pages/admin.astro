---
// /admin - Admin Dashboard
// Access control is enforced by the satellite canister (get_errors returns Err if not admin).
// This page is client-rendered: it calls get_errors after auth and shows the result.
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="TRESR Admin">
  <div class="container mx-auto max-w-7xl px-4 py-8">
    <!-- Page header -->
    <div class="mb-6 text-center">
      <h1 class="text-2xl font-bold">🛡 Admin Dashboard</h1>
    </div>

    <!-- Loading state -->
    <div id="loading" class="flex justify-center py-20">
      <span class="loading loading-ring loading-lg"></span>
    </div>

    <!-- Access denied -->
    <div id="unauthorized" class="hero hidden min-h-[80vh]">
      <div class="hero-content flex-col text-center">
        <!-- Pulsing skull -->
        <div class="relative mb-4">
          <div class="bg-error/20 absolute inset-0 animate-ping rounded-full">
          </div>
          <div
            class="border-error/60 bg-error/10 relative flex h-28 w-28 items-center justify-center rounded-full border-2 text-6xl shadow-[0_0_40px_rgba(239,68,68,0.4)]"
          >
            💀
          </div>
        </div>

        <!-- Heading -->
        <h2
          class="font-display text-error text-5xl font-black tracking-[0.2em] uppercase drop-shadow-[0_0_20px_rgba(239,68,68,0.8)] sm:text-7xl"
        >
          Access Denied
        </h2>

        <!-- Alert box -->
        <div
          role="alert"
          class="alert alert-error alert-vertical sm:alert-horizontal mt-6 max-w-sm"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-6 w-6 shrink-0 stroke-current"
            fill="none"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z"
            ></path>
          </svg>
          <div>
            <h3 class="font-bold">Unauthorized territory</h3>
            <div class="text-xs opacity-80">
              This session has been flagged. Admin access only.
            </div>
          </div>
        </div>

        <!-- CTA -->
        <a
          href="/"
          class="btn btn-error btn-lg mt-8 gap-2 shadow-[0_0_20px_rgba(239,68,68,0.5)]"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-5 w-5"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
          </svg>
          Return Home
        </a>
      </div>
    </div>

    <!-- Tab panel (shown after auth confirmed) -->
    <div id="admin-panel" class="hidden">
      <!-- Tabs -->
      <div role="tablist" class="tabs tabs-box mb-6">
        <input
          type="radio"
          name="admin-tabs"
          role="tab"
          class="tab"
          aria-label="⚠️ Errors"
          id="tab-errors"
          checked
        />
        <div
          role="tabpanel"
          class="tab-content bg-base-100 border-base-300 rounded-box p-4"
        >
          <!-- ─── Errors Tab ─────────────────────────────────────────────── -->
          <div class="mb-6 flex flex-col gap-4">
            <h2 class="text-xl font-bold">
              Error Records (<span id="error-count">0</span>)
            </h2>

            <!-- Filter & Controls Bar -->
            <div
              class="bg-base-200 border-base-300 rounded-t-box flex flex-wrap items-center justify-between gap-4 border border-b-0 p-3"
            >
              <!-- Filters (Left) -->
              <div class="flex flex-1 flex-wrap items-center gap-3">
                <label
                  class="input input-bordered input-sm flex w-full max-w-xs items-center gap-2"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 16 16"
                    class="h-4 w-4 opacity-70"
                  >
                    <path
                      fill-rule="evenodd"
                      d="M9.965 11.026a5 5 0 1 1 1.06-1.06l2.755 2.754a.75.75 0 1 1-1.06 1.06l-2.755-2.754ZM10.5 7a3.5 3.5 0 1 1-7 0 3.5 3.5 0 0 1 7 0Z"
                      clip-rule="evenodd"></path>
                  </svg>
                  <input
                    id="search"
                    type="text"
                    placeholder="Search ID, Component, Message..."
                    class="grow"
                  />
                </label>
                <select
                  id="filter-env"
                  class="select select-bordered select-sm"
                >
                  <option value="">All environments</option>
                  <option value="mainnet">mainnet</option>
                  <option value="testnet">testnet</option>
                  <option value="anvil">anvil</option>
                </select>
                <select
                  id="filter-resolved"
                  class="select select-bordered select-sm"
                >
                  <option value="">All statuses</option>
                  <option value="false">Unresolved</option>
                  <option value="true">Resolved</option>
                </select>
              </div>

              <!-- Actions & Selection (Right) -->
              <div class="flex flex-wrap items-center gap-3">
                <div
                  id="selection-bar"
                  class="border-base-300 hidden items-center gap-3 border-r pr-3"
                >
                  <label class="label cursor-pointer gap-2 p-0">
                    <input
                      id="select-all"
                      type="checkbox"
                      class="checkbox checkbox-sm"
                    />
                    <span class="label-text text-sm font-semibold"
                      >Select all</span
                    >
                  </label>
                  <span id="selected-count" class="badge badge-neutral badge-sm"
                    >0</span
                  >
                </div>

                <div class="flex gap-2">
                  <button
                    id="delete-selected-btn"
                    class="btn btn-error btn-sm hidden"
                    disabled
                  >
                    🗑 Delete
                  </button>
                  <button id="refresh-btn" class="btn btn-ghost btn-sm">
                    ↺ Refresh
                  </button>
                </div>
              </div>
            </div>

            <div
              class="border-base-300 rounded-b-box overflow-x-auto border border-t-0"
            >
              <table class="table-sm table">
                <thead>
                  <tr>
                    <th
                      ><input
                        id="select-all-head"
                        type="checkbox"
                        class="checkbox checkbox-xs"
                      /></th
                    >
                    <th>Error ID</th>
                    <th>Component</th>
                    <th>Message</th>
                    <th>Principal</th>
                    <th>Env</th>
                    <th>Time</th>
                    <th>Status</th>
                    <th>Actions</th>
                  </tr>
                </thead>
                <tbody id="error-table-body"> </tbody>
              </table>
            </div>
          </div>
        </div>

        <input
          type="radio"
          name="admin-tabs"
          role="tab"
          class="tab"
          aria-label="💰 Economy"
          id="tab-economy"
        />
        <div
          role="tabpanel"
          class="tab-content bg-base-100 border-base-300 rounded-box p-4"
        >
          <!-- ─── Economy Tab ─────────────────────────────────────────────── -->
          <div class="mb-4 flex flex-wrap items-center gap-3">
            <h2 class="flex-1 text-xl font-bold">Economy</h2>
            <button id="refresh-economy-btn" class="btn btn-ghost btn-sm"
              >↺ Refresh</button
            >
          </div>

          <div id="economy-loading" class="flex hidden justify-center py-12">
            <span class="loading loading-dots loading-md"></span>
          </div>

          <!-- Global comparison -->
          <div id="economy-comparison" class="hidden">
            <!-- Blockchain -->
            <div class="mb-4">
              <div class="mb-2 flex items-center gap-2">
                <span class="font-mono text-xs font-bold uppercase opacity-60"
                  >⛓ Blockchain (Live)</span
                >
                <span id="chain-status" class="badge badge-xs badge-ghost"
                  >loading…</span
                >
              </div>
              <div
                class="stats stats-vertical bg-base-200 md:stats-horizontal w-full shadow"
              >
                <div class="stat">
                  <div class="stat-title">Fees</div>
                  <div id="chain-fees" class="stat-value text-info text-lg">
                    —
                  </div>
                  <div class="stat-desc">vault.totalFeesCollected()</div>
                </div>
                <div class="stat">
                  <div class="stat-title">Rewards</div>
                  <div
                    id="chain-rewarded"
                    class="stat-value text-success text-lg"
                  >
                    —
                  </div>
                  <div class="stat-desc">vault.totalRewardsPaid()</div>
                </div>
                <div class="stat">
                  <div class="stat-title">Burned</div>
                  <div id="chain-burned" class="stat-value text-error text-lg">
                    —
                  </div>
                  <div class="stat-desc">vault.totalBurned()</div>
                </div>
                <div class="stat">
                  <div class="stat-title">Vault Balance</div>
                  <div id="chain-vault" class="stat-value text-warning text-lg">
                    —
                  </div>
                  <div class="stat-desc">vault.currentBalance()</div>
                </div>
              </div>
            </div>

            <!-- Discrepancy alerts -->
            <div id="economy-alerts" class="mb-6 flex flex-col gap-2"></div>

            <!-- Per-user balance table -->
            <div class="mb-2 font-mono text-xs font-bold uppercase opacity-60">
              👤 Per-User Balance Audit
            </div>
            <div class="rounded-box border-base-300 overflow-x-auto border">
              <table class="table-sm table">
                <thead>
                  <tr>
                    <th>Principal</th>
                    <th>Nickname</th>
                    <th>On-Chain Balance</th>
                  </tr>
                </thead>
                <tbody id="economy-table-body">
                  <tr>
                    <td colspan="3" class="py-8 text-center opacity-50"
                      >Click Refresh to load economy data</td
                    >
                  </tr>
                </tbody>
              </table>
            </div>
          </div>
        </div>

        <input
          type="radio"
          name="admin-tabs"
          role="tab"
          class="tab"
          aria-label="🚫 Anti-Cheat"
          id="tab-anticheat"
        />
        <div
          role="tabpanel"
          class="tab-content bg-base-100 border-base-300 rounded-box p-4"
        >
          <!-- ─── Anti-Cheat Tab ──────────────────────────────────────────── -->
          <div class="mb-4 flex items-center gap-3">
            <h2 class="flex-1 text-xl font-bold">
              Banned Users (<span id="banned-count">0</span>)
            </h2>
            <button id="refresh-anticheat-btn" class="btn btn-ghost btn-sm"
              >↺ Refresh</button
            >
          </div>

          <div id="anticheat-loading" class="flex hidden justify-center py-12">
            <span class="loading loading-dots loading-md"></span>
          </div>

          <div class="rounded-box border-base-300 overflow-x-auto border">
            <table class="table-sm table">
              <thead>
                <tr>
                  <th>Principal</th>
                  <th>Nickname</th>
                  <th>Offences</th>
                  <th>Banned Until</th>
                  <th>Status</th>
                </tr>
              </thead>
              <tbody id="anticheat-table-body">
                <tr>
                  <td colspan="5" class="py-8 text-center opacity-50"
                    >Click Refresh to load ban data</td
                  >
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Return Home & Calculator -->
  <div class="mt-10 mb-8 flex justify-center gap-4">
    <a
      href="/"
      class="btn btn-outline btn-primary btn-sm font-mono tracking-widest"
    >
      ← RETURN HOME
    </a>
    <a
      href="/calc"
      class="btn btn-outline btn-secondary btn-sm font-mono tracking-widest"
      title="Secret Prize Calculator"
    >
      🧮 CALCULATOR
    </a>
  </div>

  <!-- Error detail modal -->
  <dialog id="error-detail-modal" class="modal modal-middle">
    <div class="modal-box border-base-content/10 bg-base-300 max-w-2xl border">
      <div class="mb-4 flex items-center justify-between">
        <h3 class="font-display text-lg font-bold tracking-wide">
          Error Detail
        </h3>
        <form method="dialog">
          <button class="btn btn-circle btn-ghost btn-sm">✕</button>
        </form>
      </div>
      <div class="space-y-3">
        <div>
          <div class="mb-1 text-xs font-bold uppercase opacity-50">
            Principal
          </div>
          <div
            id="detail-principal"
            class="bg-base-200 rounded p-2 font-mono text-xs break-all opacity-80"
          >
          </div>
        </div>
        <div>
          <div class="mb-1 text-xs font-bold uppercase opacity-50">
            Raw Error
          </div>
          <pre
            id="detail-raw-error"
            class="bg-base-200 max-h-64 overflow-y-auto rounded p-3 font-mono text-xs break-all whitespace-pre-wrap">
          </pre>
        </div>
      </div>
      <div class="modal-action">
        <form method="dialog">
          <button class="btn btn-ghost btn-sm">Close</button>
        </form>
      </div>
    </div>
    <form method="dialog" class="modal-backdrop">
      <button>close</button>
    </form>
  </dialog>

  <script>
    import {initSatellite, listDocs} from "@junobuild/core";
    import {functions as satelliteApi} from "@/declarations/satellite/satellite.api";
    const {getErrors, deleteErrors, resolveError} = satelliteApi;
    import type {ErrorRecord} from "@/declarations/satellite/satellite.did";
    import type {UserProfile} from "@/types/backend";
    import {getTresrBalance, formatBalance} from "@/lib/blockchain/balance";
    import {getEnvironmentKey} from "@/lib/blockchain/networks/chain";
    import {
      getTotalFees,
      getTotalRewards,
      getVaultTotalBurned,
      getVaultCurrentBalance,
    } from "@/lib/blockchain/contracts/vault";
    import {config} from "@/lib/config/client";
    import {log} from "@/lib/utils/log";

    // ─── State ────────────────────────────────────────────────────────────

    let allErrors: ErrorRecord[] = [];
    const selected = new Set<string>();

    // ─── DOM refs ──────────────────────────────────────────────────────────

    const loading = document.getElementById("loading")!;
    const unauthorized = document.getElementById("unauthorized")!;
    const adminPanel = document.getElementById("admin-panel")!;
    const tableBody = document.getElementById("error-table-body")!;
    const errorCount = document.getElementById("error-count")!;
    const deleteBtn = document.getElementById(
      "delete-selected-btn"
    ) as HTMLButtonElement;
    const searchInput = document.getElementById("search") as HTMLInputElement;
    const filterEnv = document.getElementById(
      "filter-env"
    ) as HTMLSelectElement;
    const filterResolved = document.getElementById(
      "filter-resolved"
    ) as HTMLSelectElement;
    const selectionBar = document.getElementById("selection-bar")!;
    const selectedCount = document.getElementById("selected-count")!;
    const selectAll = document.getElementById("select-all") as HTMLInputElement;
    const selectAllHead = document.getElementById(
      "select-all-head"
    ) as HTMLInputElement;

    // ─── Helpers ─────────────────────────────────────────────────────────

    function escHtml(s: string) {
      return s
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;");
    }

    // ─── Errors Tab ───────────────────────────────────────────────────────

    async function loadErrors() {
      loading.classList.remove("hidden");
      adminPanel.classList.add("hidden");
      unauthorized.classList.add("hidden");

      try {
        const result = await getErrors();

        if ("Err" in result) {
          loading.classList.add("hidden");
          unauthorized.classList.remove("hidden");
          return;
        }

        allErrors = result.Ok;
        loading.classList.add("hidden");
        adminPanel.classList.remove("hidden");
        selectionBar.classList.remove("hidden");
        renderErrorTable();
      } catch (e) {
        loading.classList.add("hidden");
        unauthorized.classList.remove("hidden");
        log.error("Admin", "Failed to load error records", e);
      }
    }

    function getFiltered(): ErrorRecord[] {
      const q = searchInput.value.toLowerCase();
      const env = filterEnv.value;
      const res = filterResolved.value;
      return allErrors.filter((r) => {
        if (env && r.environment !== env) return false;
        if (res === "true" && !r.resolved) return false;
        if (res === "false" && r.resolved) return false;
        if (
          q &&
          !r.error_id.toLowerCase().includes(q) &&
          !r.component.toLowerCase().includes(q) &&
          !r.message.toLowerCase().includes(q) &&
          !r.principal.toLowerCase().includes(q)
        )
          return false;
        return true;
      });
    }

    function renderErrorTable() {
      const rows = getFiltered();
      errorCount.textContent = String(rows.length);
      tableBody.innerHTML = "";

      if (rows.length === 0) {
        tableBody.innerHTML =
          '<tr><td colspan="8" class="text-center opacity-50 py-8">No errors found</td></tr>';
        return;
      }

      for (const r of rows) {
        const ts = new Date(Number(r.timestamp_ms)).toLocaleString();
        const tr = document.createElement("tr");
        tr.className = `hover ${selected.has(r.error_id) ? "bg-base-300" : ""}`;
        const resolveLabel = r.resolved ? "↩ Reopen" : "✓ Resolve";
        const resolveClass = r.resolved
          ? "btn btn-xs btn-ghost text-warning"
          : "btn btn-xs btn-ghost text-success";
        tr.innerHTML = `
          <td><input type="checkbox" class="checkbox checkbox-xs row-check" data-id="${r.error_id}" ${selected.has(r.error_id) ? "checked" : ""} /></td>
          <td><code class="text-xs font-mono">${r.error_id}</code></td>
          <td class="text-xs font-mono">${escHtml(r.component)}</td>
          <td class="max-w-xs truncate text-xs" title="${escHtml(r.message)}">${escHtml(r.message)}</td>
          <td class="text-xs font-mono truncate max-w-[120px]" title="${escHtml(r.principal)}">${escHtml(r.principal.slice(0, 12))}…</td>
          <td><span class="badge badge-xs ${r.environment === "mainnet" ? "badge-warning" : r.environment === "testnet" ? "badge-info" : "badge-ghost"}">${r.environment}</span></td>
          <td class="text-xs whitespace-nowrap">${ts}</td>
          <td>${r.resolved ? '<span class="badge badge-success badge-xs">resolved</span>' : '<span class="badge badge-error badge-xs">open</span>'}</td>
          <td><button class="${resolveClass} resolve-btn" data-id="${r.error_id}" data-resolved="${r.resolved}">${resolveLabel}</button></td>
        `;

        tr.addEventListener("click", (e) => {
          if ((e.target as HTMLInputElement).type === "checkbox") return;
          const detailModal = document.getElementById(
            "error-detail-modal"
          ) as HTMLDialogElement;
          const detailPrincipal = document.getElementById("detail-principal");
          const detailRawError = document.getElementById("detail-raw-error");
          if (detailPrincipal) detailPrincipal.textContent = r.principal;
          if (detailRawError) detailRawError.textContent = r.raw_error;
          detailModal?.showModal();
        });

        tableBody.appendChild(tr);
      }

      for (const cb of Array.from(
        tableBody.querySelectorAll<HTMLInputElement>(".row-check")
      )) {
        cb.addEventListener("change", () => {
          if (cb.checked) selected.add(cb.dataset.id!);
          else selected.delete(cb.dataset.id!);
          updateSelectionUI();
        });
      }

      // Resolve / Reopen buttons
      for (const btn of Array.from(
        tableBody.querySelectorAll<HTMLButtonElement>(".resolve-btn")
      )) {
        btn.addEventListener("click", async (e) => {
          e.stopPropagation();
          const errorId = btn.dataset.id!;
          const wasResolved = btn.dataset.resolved === "true";
          btn.disabled = true;
          btn.textContent = "…";
          try {
            const res = await resolveError(errorId, !wasResolved);
            if ("Err" in res) {
              alert(`Failed to update status: ${res.Err}`);
              btn.disabled = false;
              btn.textContent = wasResolved ? "↩ Reopen" : "✓ Resolve";
              return;
            }
            // Update local state and re-render
            const idx = allErrors.findIndex((r) => r.error_id === errorId);
            if (idx !== -1)
              allErrors[idx] = {...allErrors[idx], resolved: !wasResolved};
            renderErrorTable();
          } catch (err) {
            alert(`Failed: ${String(err)}`);
            btn.disabled = false;
            btn.textContent = wasResolved ? "↩ Reopen" : "✓ Resolve";
          }
        });
      }
    }

    function updateSelectionUI() {
      selectedCount.textContent = `${selected.size} selected`;
      if (selected.size > 0) {
        deleteBtn.classList.remove("hidden");
        deleteBtn.disabled = false;
      } else {
        deleteBtn.classList.add("hidden");
        deleteBtn.disabled = true;
      }
    }

    deleteBtn.addEventListener("click", async () => {
      if (selected.size === 0) return;
      if (
        !confirm(
          `Delete ${selected.size} error record(s)? This cannot be undone.`
        )
      )
        return;

      try {
        const result = await deleteErrors([...selected]);
        if ("Err" in result) {
          alert(`Delete failed: ${result.Err}`);
          return;
        }
        selected.clear();
        updateSelectionUI();
        await loadErrors();
      } catch (e) {
        alert(`Delete failed: ${String(e)}`);
      }
    });

    document
      .getElementById("refresh-btn")!
      .addEventListener("click", loadErrors);
    searchInput.addEventListener("input", renderErrorTable);
    filterEnv.addEventListener("change", renderErrorTable);
    filterResolved.addEventListener("change", renderErrorTable);

    selectAll.addEventListener("change", () => {
      for (const r of getFiltered()) {
        if (selectAll.checked) selected.add(r.error_id);
        else selected.delete(r.error_id);
      }
      renderErrorTable();
      updateSelectionUI();
    });

    selectAllHead.addEventListener("change", () => {
      selectAll.checked = selectAllHead.checked;
      selectAll.dispatchEvent(new Event("change"));
    });

    // ─── Economy Tab ──────────────────────────────────────────────────────

    async function loadEconomy() {
      const econLoading = document.getElementById("economy-loading")!;
      const econComparison = document.getElementById("economy-comparison")!;
      const econBody = document.getElementById("economy-table-body")!;
      const alertsEl = document.getElementById("economy-alerts")!;
      const chainStatus = document.getElementById("chain-status")!;

      econLoading.classList.remove("hidden");
      econComparison.classList.add("hidden");
      econBody.innerHTML = "";
      alertsEl.innerHTML = "";

      try {
        // ── 1. Blockchain ─────────────────────────────────────────────────
        let chainFees = 0n;
        let chainRewarded = 0n;
        let chainBurned = 0n;
        let chainVault = 0n;
        let chainOnline = false;

        try {
          const env = getEnvironmentKey();
          const vaultAddr = config.blockchain.avalanche[env]
            .vault_contract as `0x${string}`;

          if (
            vaultAddr &&
            vaultAddr !== "0x0000000000000000000000000000000000000000"
          ) {
            const [fees, rewarded, burned, vault] = await Promise.all([
              getTotalFees(),
              getTotalRewards(),
              getVaultTotalBurned(),
              getVaultCurrentBalance(),
            ]);
            chainFees = fees as bigint;
            chainRewarded = rewarded as bigint;
            chainBurned = burned as bigint;
            chainVault = vault;
            chainOnline = true;
          }
        } catch {
          // RPC offline — show dashes
        }

        if (chainOnline) {
          chainStatus.textContent = "online";
          chainStatus.className = "badge badge-xs badge-success";
        } else {
          chainStatus.textContent = "offline";
          chainStatus.className = "badge badge-xs badge-error";
        }

        document.getElementById("chain-fees")!.textContent = chainOnline
          ? formatBalance(chainFees)
          : "—";
        document.getElementById("chain-rewarded")!.textContent = chainOnline
          ? formatBalance(chainRewarded)
          : "—";
        document.getElementById("chain-burned")!.textContent = chainOnline
          ? formatBalance(chainBurned)
          : "—";
        document.getElementById("chain-vault")!.textContent = chainOnline
          ? formatBalance(chainVault)
          : "—";

        alertsEl.innerHTML = "";

        // ── 2. Per-user audit ─────────────────────────────────────────────
        const usersResult = await listDocs<UserProfile>({
          collection: "users",
        });

        const rows: string[] = [];

        for (const doc of usersResult.items) {
          const profile = doc.data;
          const principal = doc.key;
          const nickname = escHtml(profile.nickname ?? "—");
          let onChainBalance = 0n;

          if (profile.evm_wallet) {
            try {
              onChainBalance = await getTresrBalance(profile.evm_wallet, false);
            } catch {
              // RPC unavailable — show 0
            }
          }

          rows.push(
            `<tr>` +
              `<td class="text-xs font-mono truncate max-w-[120px]" title="${escHtml(principal)}">${escHtml(principal.slice(0, 14))}…</td>` +
              `<td>${nickname}</td>` +
              `<td class="font-mono text-xs">${formatBalance(onChainBalance)}</td>` +
              `</tr>`
          );
        }

        econLoading.classList.add("hidden");
        econComparison.classList.remove("hidden");
        econBody.innerHTML =
          rows.length > 0
            ? rows.join("")
            : '<tr><td colspan="3" class="py-8 text-center opacity-50">No users found</td></tr>';
      } catch (e) {
        econLoading.classList.add("hidden");
        econComparison.classList.remove("hidden");
        econBody.innerHTML = `<tr><td colspan="3" class="py-8 text-center text-error">Failed to load economy data: ${escHtml(String(e))}</td></tr>`;
      }
    }

    document
      .getElementById("refresh-economy-btn")!
      .addEventListener("click", loadEconomy);

    // ─── Anti-Cheat Tab ───────────────────────────────────────────────────

    async function loadBans() {
      const acLoading = document.getElementById("anticheat-loading")!;
      const acBody = document.getElementById("anticheat-table-body")!;
      const bannedCountEl = document.getElementById("banned-count")!;
      acLoading.classList.remove("hidden");
      acBody.innerHTML = "";

      try {
        const usersResult = await listDocs<UserProfile>({
          collection: "users",
        });

        const now = Date.now();
        const banned = usersResult.items.filter(
          (doc) =>
            doc.data.banned_until != null && (doc.data.banned_until ?? 0) > now
        );

        bannedCountEl.textContent = String(banned.length);

        if (banned.length === 0) {
          acLoading.classList.add("hidden");
          acBody.innerHTML =
            '<tr><td colspan="5" class="py-8 text-center opacity-50">No banned users 🎉</td></tr>';
          return;
        }

        const rows = banned.map((doc) => {
          const profile = doc.data;
          const principal = doc.key;
          const nickname = escHtml(profile.nickname ?? "—");
          const offences = profile.offence_count ?? 0;
          const bannedUntil = profile.banned_until ?? 0;

          let banUntilLabel: string;
          let statusBadge: string;

          if (bannedUntil >= Number.MAX_SAFE_INTEGER) {
            banUntilLabel = "♾️ Permanent";
            statusBadge =
              '<span class="badge badge-error badge-sm">Permanent</span>';
          } else {
            const expiry = new Date(bannedUntil).toLocaleString();
            banUntilLabel = expiry;
            const isActive = bannedUntil > now;
            statusBadge = isActive
              ? '<span class="badge badge-warning badge-sm">Active</span>'
              : '<span class="badge badge-ghost badge-sm">Expired</span>';
          }

          return `<tr>
            <td class="text-xs font-mono truncate max-w-[120px]" title="${escHtml(principal)}">${escHtml(principal.slice(0, 14))}…</td>
            <td>${nickname}</td>
            <td><span class="badge badge-outline badge-sm">${offences}</span></td>
            <td class="text-xs whitespace-nowrap">${banUntilLabel}</td>
            <td>${statusBadge}</td>
          </tr>`;
        });

        acLoading.classList.add("hidden");
        acBody.innerHTML = rows.join("");
      } catch (e) {
        acLoading.classList.add("hidden");
        acBody.innerHTML = `<tr><td colspan="5" class="py-8 text-center text-error">Failed to load ban data: ${escHtml(String(e))}</td></tr>`;
      }
    }

    document
      .getElementById("refresh-anticheat-btn")!
      .addEventListener("click", loadBans);

    // ─── Init ─────────────────────────────────────────────────────────────

    (async () => {
      await initSatellite();
      // Load all tabs in parallel after auth is confirmed via loadErrors
      await loadErrors();
      // Economy and bans can load concurrently (they don't require auth gating)
      void Promise.all([loadEconomy(), loadBans()]);
    })();
  </script>
</BaseLayout>
