---
import Header from "@/components/user/Header.astro";
import ProfileModal from "@/components/user/ProfileModal.astro";
import UpdatePrompt from "@/components/pwa/UpdatePrompt.astro";
import NotificationToast from "@/components/notifications/NotificationToast.astro";
import Confetti from "@/components/effects/Confetti.astro";

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "A cyberpunk platformer game powered by the Internet Computer",
} = Astro.props;
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#1a1025" />
    <link rel="icon" type="image/png" href="/assets/icons/ios/32.png" />
    <link rel="manifest" href="/manifest.json" />
    <script is:inline>
      window.startTime = Date.now();
      // Apply saved theme immediately to prevent flash of wrong theme colors
      (function () {
        var t = localStorage.getItem("theme");
        if (t) document.documentElement.setAttribute("data-theme", t);
      })();
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;500;600;700;800;900&family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body class="bg-base-300 min-h-screen overflow-x-hidden">
    <Header />
    <main>
      <slot />
    </main>
    <UpdatePrompt />
    <NotificationToast />
    <ProfileModal />
    <Confetti />
    <script>
      import PWA from "@/lib/pwa";
      import {initAnalytics, trackPageView} from "@/lib/metrics/analytics";

      // Register PWA on load
      document.addEventListener("DOMContentLoaded", async () => {
        PWA.getInstance().register();
        await initAnalytics();
        await trackPageView(window.location.pathname);
      });
    </script>
  </body>
</html>

<style is:global>
  @import "../styles/global.css";

  /* Orbitron for headings - cyberpunk style */
  h1,
  h2,
  h3,
  .font-display {
    font-family: "Orbitron", sans-serif;
  }
</style>
