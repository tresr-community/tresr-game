---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ClaimsList from "@/components/wallet/ClaimsList.astro";
import Confetti from "@/components/effects/Confetti.astro";
import Footer from "@/components/user/Footer.astro";
import type {ConfigTypes} from "@/types/config.ts";
import {config} from "@/lib/config/client.ts";

const appName: ConfigTypes["app"]["name"] = config.app.name;
---

<BaseLayout title={`Claims | ${appName}`}>
  <Confetti />

  <!-- Terminal Grid Background -->
  <div
    class="pointer-events-none fixed inset-0 z-[-1] bg-[linear-gradient(rgba(18,16,11,0.8)_2px,transparent_2px),linear-gradient(90deg,rgba(18,16,11,0.8)_2px,transparent_2px)] bg-[size:40px_40px] opacity-20"
  >
  </div>

  <div
    class="relative flex min-h-dvh flex-col px-4 pt-24 pb-12 sm:px-6 lg:px-8"
  >
    <div class="mx-auto w-full max-w-5xl flex-grow">
      <!-- Header Section -->
      <div class="mb-10 space-y-4 text-center">
        <h1
          class="font-display text-warning animate-pulse text-4xl font-black drop-shadow-[0_0_15px_rgba(var(--warning),0.6)] md:text-6xl"
        >
          🎉 CLAIM YOUR PRIZES 🎉
        </h1>
        <p
          class="text-base-content/80 mx-auto max-w-2xl font-mono text-lg tracking-wide md:text-xl"
        >
          🤑 Let's get that $TRESR! 🤑
        </p>
      </div>

      <!-- Main Content Area -->
      <div
        class="bg-base-200/80 border-warning/20 rounded-3xl border p-4 shadow-2xl backdrop-blur md:p-8"
      >
        <ClaimsList />
      </div>
    </div>

    <div class="mt-auto pt-10 text-center">
      <div class="mb-8">
        <a
          href="/"
          class="btn btn-outline btn-primary font-mono tracking-widest"
        >
          RETURN HOME
        </a>
      </div>
      <Footer />
    </div>
  </div>

  <!-- Confetti Container (Script in ClaimsList will trigger this) -->
  <div
    id="confetti-container"
    class="pointer-events-none fixed inset-0 z-50 overflow-hidden"
  >
  </div>
</BaseLayout>
