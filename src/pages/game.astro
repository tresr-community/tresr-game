---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PhaserGame from "@/components/game/PhaserGame.astro";
import FeeGate from "@/components/game/FeeGate.astro";
import BanModal from "@/components/game/BanModal.astro";
import Loader from "@/components/game/Loader.astro";
---

<BaseLayout title="TRESR Game | Active Session">
  <Loader minTime={1500} id="game-loader" />
  <FeeGate />
  <BanModal />

  <div
    id="game-container"
    class="fixed inset-0 hidden h-screen w-full touch-none overflow-hidden"
  >
    <PhaserGame />
  </div>

  <script>
    import {getAuthState, initAuth} from "@/lib/auth";
    import {checkDeviceBan} from "@/lib/auth/ban";
    import {isGuestRateLimited} from "@/lib/auth/guest";
    import {isFeePaid, showFeeGate} from "@/lib/game/fee-gate";
    import {profileStore} from "@/lib/user/store";
    import {trackGameStart} from "@/lib/metrics/analytics";
    import {config} from "@/lib/config/client";
    import {log} from "@/lib/utils/log";

    const COMPONENT_NAME = "GamePage";

    function checkBan(): boolean {
      const profile = profileStore.get();
      if (!profile) return false;

      const bannedUntil = profile.banned_until;
      if (bannedUntil == null) return false;

      const now = Date.now();
      if (bannedUntil > now) {
        log.info(COMPONENT_NAME, `User is banned until ${bannedUntil}`);
        document.dispatchEvent(
          new CustomEvent("tresr:ban-modal-open", {
            detail: {
              bannedUntil,
              offenceCount: profile.offence_count ?? 0,
            },
          })
        );
        return true;
      }

      return false;
    }

    async function checkAuthAndFee() {
      await initAuth();
      const auth = getAuthState();

      if (!auth.isAuthenticated) {
        window.location.href = "/";
        return;
      }

      // Check device-level ban first — applies to ALL modes (ticket #203)
      const deviceBan = checkDeviceBan();
      if (deviceBan) {
        log.info(COMPONENT_NAME, "Device is banned, showing ban modal");
        document.dispatchEvent(
          new CustomEvent("tresr:ban-modal-open", {
            detail: {
              bannedUntil: deviceBan.bannedUntil,
              offenceCount: deviceBan.offenceCount,
            },
          })
        );
        return;
      }

      // Check profile-level ban (authenticated users with Juno profile)
      if (checkBan()) {
        return;
      }

      // Guests skip fee gate (rate limit enforced at START button,
      // but also checked here as fallback for direct URL navigation)
      if (auth.isGuest) {
        if (isGuestRateLimited()) {
          log.info(COMPONENT_NAME, "Guest rate limit reached, redirecting");
          window.location.href = "/";
          return;
        }
        log.info(COMPONENT_NAME, "Guest mode - skipping fee gate");
        startGame();
        return;
      }

      // IID users without a linked wallet cannot pay the fee
      const profile = profileStore.get();
      if (profile && !profile.wallet.evmWalletLinked) {
        log.info(COMPONENT_NAME, "No wallet linked, cannot enter fee gate");
        window.showWarningToast("You need to link a wallet first");
        window.location.href = "/";
        return;
      }

      // Skip fee gate if vault contract hasn't been deployed yet (zero address)
      const {isVaultDeployed} = await import("@/lib/wallet/avalanche");
      if (!isVaultDeployed(config)) {
        log.info(COMPONENT_NAME, "Vault not deployed, skipping fee gate");
        startGame();
        return;
      }

      // Degens must pay the fee
      if (await isFeePaid()) {
        log.info(COMPONENT_NAME, "Fee already paid this session");
        startGame();
        return;
      }

      // Show fee gate modal — blocks until paid or aborted.
      // Timeout applies to blockchain transaction confirmation, not modal display.
      const feeTimeout = config.gameplay.fee_gate.transaction_timeout_ms;
      try {
        await showFeeGate(feeTimeout);
        log.info(COMPONENT_NAME, "Fee paid successfully");
        startGame();
      } catch (err: unknown) {
        const msg = err instanceof Error ? err.message : String(err);
        if (msg.includes("timed out")) {
          log.error(COMPONENT_NAME, "Fee gate transaction timed out");
          window.location.href = "/";
        } else {
          log.info(COMPONENT_NAME, "Fee payment aborted, returning to home");
          window.location.href = "/";
        }
      }
    }

    // Orientation lock — landscape during gameplay (ticket #190)
    // Screen Orientation API lock/unlock not in all TS lib definitions
    // eslint-disable-next-line @typescript-eslint/no-explicit-any
    const orientation = screen.orientation as any;

    async function requestLandscapeLock() {
      try {
        if (orientation?.lock) {
          await orientation.lock("landscape");
          log.info(COMPONENT_NAME, "Screen orientation locked to landscape");
        }
      } catch {
        // API not supported or requires fullscreen — graceful fallback
        log.debug(COMPONENT_NAME, "Orientation lock not available");
      }
    }

    function releaseLandscapeLock() {
      try {
        if (orientation?.unlock) {
          orientation.unlock();
        }
      } catch {
        // Ignore
      }
    }

    // Wake Lock — prevent screen dimming during gameplay
    let wakeLock: WakeLockSentinel | null = null;

    async function requestWakeLock() {
      try {
        if ("wakeLock" in navigator) {
          wakeLock = await navigator.wakeLock.request("screen");
          log.info(COMPONENT_NAME, "Wake lock acquired");
          // Re-acquire on visibility change (lost when tabbing away)
          document.addEventListener("visibilitychange", reacquireWakeLock);
        }
      } catch {
        log.debug(COMPONENT_NAME, "Wake lock not available");
      }
    }

    async function reacquireWakeLock() {
      if (document.visibilityState === "visible" && !wakeLock) {
        try {
          wakeLock = await navigator.wakeLock.request("screen");
          log.debug(COMPONENT_NAME, "Wake lock re-acquired");
        } catch {
          // Ignore
        }
      }
    }

    async function releaseWakeLock() {
      document.removeEventListener("visibilitychange", reacquireWakeLock);
      if (wakeLock) {
        try {
          await wakeLock.release();
          wakeLock = null;
          log.debug(COMPONENT_NAME, "Wake lock released");
        } catch {
          // Ignore
        }
      }
    }

    // Fullscreen — request on mobile to maximize canvas and enable orientation lock.
    // Uses documentElement instead of game-container so the header toolbar
    // remains visible above the game canvas during fullscreen gameplay.
    async function requestFullscreen() {
      const isTouchDevice =
        "ontouchstart" in window || navigator.maxTouchPoints > 0;
      if (!isTouchDevice) return;

      try {
        if (document.documentElement.requestFullscreen) {
          await document.documentElement.requestFullscreen();
          log.info(COMPONENT_NAME, "Fullscreen activated");
          // Orientation lock works reliably in fullscreen
          requestLandscapeLock();
        }
      } catch {
        log.debug(COMPONENT_NAME, "Fullscreen not available");
      }
    }

    // Audio context resume — mobile browsers block AudioContext until user interaction
    function resumeAudioContext() {
      const game = (window as any).__phaserGame;
      if (game?.sound?.context?.state === "suspended") {
        game.sound.context.resume().then(() => {
          log.info(COMPONENT_NAME, "AudioContext resumed on touch");
        });
      }
      // Remove after first successful resume
      document.removeEventListener("touchstart", resumeAudioContext);
      document.removeEventListener("click", resumeAudioContext);
    }

    function startGame() {
      const container = document.getElementById("game-container");
      if (container) {
        container.classList.remove("hidden");
      }

      // Lock body overflow during gameplay to prevent any scroll bounce
      document.body.style.overflow = "hidden";
      document.body.style.position = "fixed";
      document.body.style.inset = "0";

      requestLandscapeLock();
      requestWakeLock();
      requestFullscreen();
      trackGameStart();

      // Header stays visible during gameplay — the collapsible toggle
      // keeps it out of the way when not needed.

      // Resume audio context on first user interaction (mobile browsers block autoplay)
      document.addEventListener("touchstart", resumeAudioContext, {once: true});
      document.addEventListener("click", resumeAudioContext, {once: true});

      // Signal PhaserGame component to initialize the engine.
      // This ensures narration/music/game don't start until fee is resolved.
      log.info(COMPONENT_NAME, "Dispatching game engine start event");
      document.dispatchEvent(new CustomEvent("tresr:start-game-engine"));
    }

    // Portrait detection — pause/resume game when orientation changes
    // (portrait overlay is handled globally by BaseLayout)
    // Guard: only touch MainScene; skip if portrait state hasn't changed.
    import {SCENE_KEYS} from "@/lib/game/constants";
    let lastHandledPortrait: boolean | null = null;
    function handlePortraitChange(e: Event) {
      const {portrait} = (e as CustomEvent).detail;

      // Deduplicate — BaseLayout already deduplicates, but guard here too in
      // case other code dispatches the event independently.
      if (portrait === lastHandledPortrait) {
        log.debug(
          COMPONENT_NAME,
          "Portrait state unchanged, skipping scene transition"
        );
        return;
      }
      lastHandledPortrait = portrait;

      const game = (window as any).__phaserGame;
      if (!game) return;

      // Only affect the main gameplay scene — never touch BootScene or Preloader.
      const mainScene = game.scene.getScene(SCENE_KEYS.MAIN);
      if (!mainScene) return;

      if (portrait) {
        log.info(COMPONENT_NAME, "Portrait detected, pausing MainScene");
        if (mainScene.scene.isActive()) mainScene.scene.pause();
      } else {
        log.info(COMPONENT_NAME, "Landscape detected, resuming MainScene");
        if (mainScene.scene.isPaused()) mainScene.scene.resume();
      }
    }
    document.addEventListener("tresr:portrait-change", handlePortraitChange);

    // Release lock when leaving game page
    window.addEventListener("beforeunload", releaseLandscapeLock);

    document.addEventListener(
      "astro:before-preparation",
      () => {
        document.removeEventListener(
          "tresr:portrait-change",
          handlePortraitChange
        );
        document.removeEventListener("touchstart", resumeAudioContext);
        document.removeEventListener("click", resumeAudioContext);
        window.removeEventListener("beforeunload", releaseLandscapeLock);
        releaseLandscapeLock();
        releaseWakeLock();
        // Restore body overflow
        document.body.style.overflow = "";
        document.body.style.position = "";
        document.body.style.inset = "";
        // Exit fullscreen if active
        if (document.fullscreenElement) {
          document.exitFullscreen().catch(() => {});
        }
        // (Header no longer hidden during gameplay — no restore needed)
      },
      {once: true}
    );

    checkAuthAndFee();
  </script>
</BaseLayout>
