---

---

<dialog id="modal-fee-gate" class="modal modal-middle">
  <div
    class="modal-box border-primary/30 bg-base-300 max-h-[90vh] overflow-y-auto border p-4 text-center sm:p-6"
  >
    <h3
      class="text-primary font-display text-xl font-black tracking-widest uppercase sm:text-3xl"
    >
      Entry Fee Required
    </h3>
    <p class="py-2 text-sm opacity-70 sm:py-4 sm:text-base">
      Pay the entry fee to start your mission. Your fee enters the vault as
      potential loot.
    </p>

    <div class="stats stats-vertical bg-base-200/50 my-2 w-full shadow sm:my-4">
      <div class="stat">
        <div class="stat-title text-xs uppercase">Fee Amount</div>
        <div
          id="fee-amount-display"
          class="stat-value text-warning font-mono text-lg sm:text-2xl"
        >
          10 $tTRESR
        </div>
      </div>
    </div>

    <!-- Transaction progress steps (hidden until payment starts) -->
    <div id="fee-progress" class="my-2 hidden sm:my-4">
      <ul class="steps steps-vertical w-full text-left text-xs sm:text-sm">
        <li id="step-wallet" class="step">Connect wallet</li>
        <li id="step-balance" class="step">Check balance</li>
        <li id="step-approve" class="step">Approve token spend</li>
        <li id="step-fee" class="step">Pay fee to vault</li>
        <li id="step-confirm" class="step">Confirm on-chain</li>
      </ul>
    </div>

    <!-- Status messages -->
    <div id="fee-status" class="my-1 hidden text-xs sm:my-2 sm:text-sm"></div>

    <div class="modal-action flex-col gap-1 sm:gap-2">
      <button id="btn-pay-fee" class="btn btn-primary btn-block gap-2">
        <span id="pay-spinner" class="loading loading-spinner loading-sm hidden"
        ></span>
        <span id="pay-label">Pay & Start Mission</span>
      </button>
      <button id="btn-fee-abort" class="btn btn-ghost btn-block">
        Abort
      </button>
    </div>
  </div>
</dialog>

<!-- Wallet reconnect overlay — shown while fee-gate dialog is closed and
     the AppKit wallet selector is opening. Prevents a confusing blank screen
     during the top-layer handoff between the native dialog and AppKit. -->
<div
  id="fee-wallet-overlay"
  class="bg-base-300/80 pointer-events-none fixed inset-0 z-[99998] hidden items-center justify-center backdrop-blur-sm"
>
  <div class="flex flex-col items-center gap-4 text-center">
    <span class="loading loading-spinner loading-lg text-primary"></span>
    <p class="text-base font-bold tracking-wide opacity-80">
      Awaiting wallet reconnection…
    </p>
  </div>
</div>

<script>
  import {config} from "@/lib/config/client";
  import {getEnvironmentKey} from "@/lib/blockchain/networks/chain";
  import {getExplorerUrl} from "@/lib/blockchain/networks/display";
  import {payFeeForGame} from "@/lib/blockchain/contracts/vault";
  import {setDoc} from "@junobuild/core";
  import {connectWallet} from "@/lib/wallet/connection";
  import {confirmReceipt} from "@/lib/blockchain/tx";
  import {getTresrBalance, formatBalance} from "@/lib/blockchain/balance";
  import {parseBalance} from "@/lib/blockchain/balance";
  import {
    markFeePaid,
    resolveFeeGate,
    rejectFeeGate,
  } from "@/lib/game/fee-gate";
  import {log} from "@/lib/utils/log";
  import {trackFeePaid, trackError} from "@/lib/metrics/analytics";
  import {reportError} from "@/lib/utils/error-reporter";

  const COMPONENT_NAME = "FeeGate";

  const modal = document.getElementById("modal-fee-gate") as HTMLDialogElement;
  const feeAmountDisplay = document.getElementById("fee-amount-display")!;
  const feeStatus = document.getElementById("fee-status")!;
  const btnPay = document.getElementById("btn-pay-fee") as HTMLButtonElement;
  const btnAbort = document.getElementById(
    "btn-fee-abort"
  ) as HTMLButtonElement;
  const paySpinner = document.getElementById("pay-spinner")!;
  const payLabel = document.getElementById("pay-label")!;

  // Read fee config
  const env = getEnvironmentKey();
  const chainConfig = config.blockchain.avalanche[env];
  const feeAmount = chainConfig.fee;
  const ticker = chainConfig.token_ticker;

  // Display fee amount
  feeAmountDisplay.textContent = `${feeAmount} $${ticker}`;

  function showStatus(message: string, isError = false) {
    feeStatus.textContent = message;
    feeStatus.classList.remove(
      "hidden",
      "text-error",
      "text-success",
      "opacity-70"
    );
    feeStatus.classList.add(isError ? "text-error" : "opacity-70");
  }

  function hideStatus() {
    feeStatus.classList.add("hidden");
  }

  // Listen for the fee gate open event from the module
  function handleFeeGateOpen() {
    hideStatus();
    hideProgress();
    btnPay.disabled = false;
    paySpinner.classList.add("hidden");
    payLabel.textContent = "Pay & Start Mission";
    btnAbort.classList.remove("hidden");
    modal.showModal();
  }
  document.addEventListener("tresr:fee-gate-open", handleFeeGateOpen);

  const feeProgress = document.getElementById("fee-progress")!;
  const steps = {
    wallet: document.getElementById("step-wallet")!,
    balance: document.getElementById("step-balance")!,
    approve: document.getElementById("step-approve")!,
    fee: document.getElementById("step-fee")!,
    confirm: document.getElementById("step-confirm")!,
  };

  function showProgress() {
    feeProgress.classList.remove("hidden");
    // Reset all steps
    Object.values(steps).forEach((s) => {
      s.classList.remove("step-primary", "step-success", "step-error");
    });
  }

  function hideProgress() {
    feeProgress.classList.add("hidden");
  }

  type StepKey = keyof typeof steps;

  function markStep(step: StepKey, state: "active" | "done" | "error") {
    const el = steps[step];
    el.classList.remove("step-primary", "step-success", "step-error");
    if (state === "active") el.classList.add("step-primary");
    else if (state === "done") el.classList.add("step-success");
    else if (state === "error") el.classList.add("step-error");
  }

  // Mutex to prevent duplicate payments on rapid clicks (ticket #168)
  let paymentInProgress = false;
  let paymentTimeoutId: ReturnType<typeof setTimeout> | null = null;
  const PAYMENT_TIMEOUT_MS = 60_000;

  function clearPaymentTimeout() {
    if (paymentTimeoutId !== null) {
      clearTimeout(paymentTimeoutId);
      paymentTimeoutId = null;
    }
  }

  // Wallet reconnect overlay — bridges the blank-screen gap between the
  // fee-gate dialog closing and the AppKit modal appearing.
  const walletOverlay = document.getElementById("fee-wallet-overlay");
  function showWalletOverlay() {
    walletOverlay?.classList.remove("hidden");
    walletOverlay?.classList.add("flex");
  }
  function hideWalletOverlay() {
    walletOverlay?.classList.add("hidden");
    walletOverlay?.classList.remove("flex");
  }

  const payHandler = async () => {
    if (paymentInProgress) return;
    paymentInProgress = true;
    btnPay.disabled = true;
    paySpinner.classList.remove("hidden");
    payLabel.textContent = "Processing...";
    btnAbort.classList.add("hidden");
    hideStatus();
    showProgress();

    try {
      // 60s hard abort: if anything hangs (locked wallet, RPC stall, etc.)
      // show a toast and send the user home rather than leaving them frozen.
      paymentTimeoutId = setTimeout(() => {
        clearPaymentTimeout();
        paymentInProgress = false;
        window.showWarningToast?.(
          "Connection timed out",
          "Your wallet took too long to respond — please try again."
        );
        modal.close();
        rejectFeeGate();
        window.location.href = "/";
      }, PAYMENT_TIMEOUT_MS);

      // Step 1: Connect wallet — always goes through connectWallet() so the
      // liveness probe fires even when a session address is already cached.
      // This catches auto-locked wallets (Brave, MetaMask) that leave wagmi
      // in a stale "connected" state without emitting a disconnect event.
      markStep("wallet", "active");
      showStatus("Connecting wallet...");
      // Close the fee-gate dialog before opening the AppKit wallet selector.
      // Native <dialog> elements occupy the browser's top layer, which sits
      // above any regular z-index stacking context — including AppKit's own
      // --w3m-z-index: 99999. Without closing first, the AppKit modal opens
      // behind the fee-gate backdrop and is invisible to the user.
      // Show the reconnect overlay first so there's no blank-screen flash.
      showWalletOverlay();
      modal.close();
      const connection = await connectWallet();
      hideWalletOverlay();
      const address = connection.address;
      markStep("wallet", "done");

      // Re-open fee-gate after wallet connected so the rest of the flow
      // (balance check, approve, pay) is visible to the user.
      modal.showModal();

      // Step 2: Check balance
      markStep("balance", "active");
      showStatus("Checking balance...");
      const balance = await getTresrBalance(address);
      const feeWei = parseBalance(String(feeAmount));

      if (balance < feeWei) {
        const formatted = formatBalance(balance);
        markStep("balance", "error");
        showStatus(
          `Insufficient balance: ${formatted} $${ticker} (need ${feeAmount} $${ticker})`,
          true
        );
        paymentInProgress = false;
        btnPay.disabled = false;
        paySpinner.classList.add("hidden");
        payLabel.textContent = "Pay & Start Mission";
        btnAbort.classList.remove("hidden");
        return;
      }
      markStep("balance", "done");

      // Generate session ID with cryptographic randomness (ticket #198)
      const ts = Date.now().toString();
      const randomBytes = crypto.getRandomValues(new Uint8Array(16));
      const randomHex = Array.from(randomBytes)
        .map((b) => b.toString(16).padStart(2, "0"))
        .join("");
      const raw = new TextEncoder().encode(`${address}:${ts}:${randomHex}`);
      const hashBuf = await crypto.subtle.digest("SHA-256", raw);
      const hashArr = new Uint8Array(hashBuf);
      const sessionId = `0x${Array.from(hashArr)
        .map((b) => b.toString(16).padStart(2, "0"))
        .join("")}`;

      // Step 3 & 4: Approve + Pay Fee (payFeeForGame does both)
      markStep("approve", "active");
      showStatus("Approve the token spend in your wallet...");

      // payFeeForGame calls approve() then payFee() — both prompt the wallet.
      // We can't hook into the middle, so we mark approve as active,
      // then update to fee after a short delay (approve is fast on local).
      const txHash = await payFeeForGame(sessionId, feeWei);
      markStep("approve", "done");
      markStep("fee", "done");

      // Step 5: Wait for on-chain confirmation (ticket #198)
      markStep("confirm", "active");
      showStatus("Confirming transaction on-chain...");
      await confirmReceipt(txHash, {component: "FeeGate"});
      markStep("confirm", "done");

      // Store session info in the fee-gate module (async — generates HMAC signature)
      await markFeePaid(txHash, sessionId);

      // Save fee to Juno audit collection
      await setDoc({
        collection: "audit",
        doc: {
          key: `fee_${txHash}`,
          data: {
            tx_hash: txHash,
            tx_url: getExplorerUrl(txHash), // optional, stored for debugging
            amount: feeAmount, // required by FeeRequest — tokens (not wei)
            status: "pending", // The rust backend verification updates this
          },
        },
      });

      trackFeePaid(txHash);
      log.info(COMPONENT_NAME, `Fee paid: ${txHash}, session: ${sessionId}`);
      showStatus("Payment confirmed! Starting mission...");

      // Brief pause so user sees the success state
      await new Promise((r) => setTimeout(r, 800));

      clearPaymentTimeout();
      modal.close();
      resolveFeeGate();
    } catch (error: unknown) {
      clearPaymentTimeout();
      hideWalletOverlay();
      const message = error instanceof Error ? error.message : String(error);
      log.error(COMPONENT_NAME, "Fee payment failed:", error);
      trackError("fee_paid", message);

      // Ensure modal is visible for error display
      if (!modal.open) modal.showModal();

      if (
        message.includes("rejected") ||
        message.includes("cancelled") ||
        message.includes("denied")
      ) {
        // User intentionally rejected — no need to file an error report
        showStatus("Transaction rejected by user.", true);
      } else {
        // Unexpected error — report to satellite and show clean reference code
        // Fire-and-forget: reportError never throws
        const errorId = await reportError(
          COMPONENT_NAME,
          "Fee payment failed",
          message
        );
        const refLine = errorId
          ? `Payment error – ref: ${errorId}`
          : `Payment error – contact support`;
        showStatus(refLine, true);
      }

      paymentInProgress = false;
      btnPay.disabled = false;
      paySpinner.classList.add("hidden");
      payLabel.textContent = "Pay & Start Mission";
      btnAbort.classList.remove("hidden");
    }
  };

  const abortHandler = () => {
    modal.close();
    rejectFeeGate();
  };

  btnPay.addEventListener("click", payHandler);
  btnAbort.addEventListener("click", abortHandler);

  // Clean up listeners on Astro navigation to prevent accumulation (ticket #289)
  document.addEventListener(
    "astro:before-preparation",
    () => {
      document.removeEventListener("tresr:fee-gate-open", handleFeeGateOpen);
      btnPay.removeEventListener("click", payHandler);
      btnAbort.removeEventListener("click", abortHandler);
    },
    {once: true}
  );
</script>
