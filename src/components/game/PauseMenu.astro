---

---

<dialog id="pause-modal" class="modal modal-middle">
  <div
    class="modal-box border-primary/30 bg-base-300 max-h-[85vh] overflow-y-auto border p-3 text-center sm:p-6"
  >
    <!-- Close button (top-right) -->
    <button
      id="btn-pause-close"
      class="btn btn-circle btn-ghost absolute top-2 right-2 min-h-[44px] min-w-[44px] text-lg"
      aria-label="Close pause menu">✕</button
    >

    <h3
      class="text-primary font-display text-xl font-black tracking-widest uppercase sm:text-4xl"
    >
      Mission Paused
    </h3>
    <p class="py-1 text-xs italic opacity-70 sm:py-4 sm:text-base">
      "Time is a flat circle, but Gary is still waiting for you."
    </p>

    <!-- Audio settings (ticket #188) -->
    <div class="bg-base-200/50 mt-1 rounded-lg p-2 sm:mt-4 sm:p-4">
      <div class="mb-2 flex items-center justify-between sm:mb-3">
        <label class="text-xs font-bold uppercase opacity-60" for="slider-music"
          >Music</label
        >
        <span id="music-vol-text" class="font-mono text-xs opacity-50">75%</span
        >
      </div>
      <input
        id="slider-music"
        type="range"
        min="0"
        max="100"
        value="75"
        class="range range-primary range-xs sm:range-sm w-full"
      />

      <div class="mt-2 mb-1 flex items-center justify-between sm:mt-3">
        <label class="text-xs font-bold uppercase opacity-60" for="slider-sfx"
          >SFX</label
        >
        <span id="sfx-vol-text" class="font-mono text-xs opacity-50">50%</span>
      </div>
      <input
        id="slider-sfx"
        type="range"
        min="0"
        max="100"
        value="50"
        class="range range-secondary range-xs sm:range-sm w-full"
      />
    </div>

    <div class="modal-action flex-col gap-1 sm:gap-2">
      <button id="btn-resume" class="btn btn-primary btn-block btn-sm sm:btn-md"
        >Get back in the fight</button
      >
      <button
        id="btn-abort"
        class="btn btn-ghost btn-block btn-sm sm:btn-md text-error"
        >Return to base</button
      >
    </div>

    <!-- Quit confirmation (ticket #187) -->
    <div id="quit-confirm" class="mt-4 hidden">
      <p class="text-error text-sm font-bold">
        Are you sure? Progress will be lost.
      </p>
      <div class="mt-2 flex gap-2">
        <button id="btn-quit-yes" class="btn btn-error btn-sm flex-1"
          >Yes, quit</button
        >
        <button id="btn-quit-cancel" class="btn btn-ghost btn-sm flex-1"
          >Cancel</button
        >
      </div>
    </div>
  </div>
</dialog>

<script>
  import {gameActions, gameState} from "@/lib/game/state";
  import MusicManager from "@/lib/game/MusicManager";

  const modal = document.getElementById("pause-modal") as HTMLDialogElement;
  const btnResume = document.getElementById("btn-resume");
  const btnAbort = document.getElementById("btn-abort");
  const quitConfirm = document.getElementById("quit-confirm");
  const btnQuitYes = document.getElementById("btn-quit-yes");
  const btnQuitCancel = document.getElementById("btn-quit-cancel");

  // Volume sliders (ticket #188)
  const sliderMusic = document.getElementById(
    "slider-music"
  ) as HTMLInputElement;
  const sliderSfx = document.getElementById("slider-sfx") as HTMLInputElement;
  const musicVolText = document.getElementById("music-vol-text");
  const sfxVolText = document.getElementById("sfx-vol-text");

  const btnPauseClose = document.getElementById("btn-pause-close");

  // Named handlers for cleanup (ticket #241)
  function handleMusicSlider() {
    const vol = parseInt(sliderMusic.value, 10) / 100;
    MusicManager.getInstance().setVolume(vol);
    if (musicVolText) musicVolText.textContent = `${sliderMusic.value}%`;
  }
  function handleSfxSlider() {
    const vol = parseInt(sliderSfx.value, 10) / 100;
    MusicManager.getInstance().setSfxVolume(vol);
    if (sfxVolText) sfxVolText.textContent = `${sliderSfx.value}%`;
  }
  function handleResume() {
    gameActions.setPaused(false);
  }
  function handleAbort() {
    quitConfirm?.classList.remove("hidden");
  }
  function handleQuitYes() {
    window.location.href = "/";
  }
  function handleQuitCancel() {
    quitConfirm?.classList.add("hidden");
  }

  sliderMusic?.addEventListener("input", handleMusicSlider);
  sliderSfx?.addEventListener("input", handleSfxSlider);
  btnResume?.addEventListener("click", handleResume);
  btnPauseClose?.addEventListener("click", handleResume);
  btnAbort?.addEventListener("click", handleAbort);
  btnQuitYes?.addEventListener("click", handleQuitYes);
  btnQuitCancel?.addEventListener("click", handleQuitCancel);

  const unsub = gameState.subscribe((state) => {
    if (state.isPaused) {
      if (!modal.open) {
        // Sync slider positions with current volume state
        if (sliderMusic) {
          sliderMusic.value = String(Math.round(state.music.musicVolume * 100));
          if (musicVolText) musicVolText.textContent = `${sliderMusic.value}%`;
        }
        if (sliderSfx) {
          sliderSfx.value = String(Math.round(state.music.sfxVolume * 100));
          if (sfxVolText) sfxVolText.textContent = `${sliderSfx.value}%`;
        }
        modal.showModal();
      }
    } else {
      if (modal.open) modal.close();
      quitConfirm?.classList.add("hidden");
    }
  });
  document.addEventListener(
    "astro:before-preparation",
    () => {
      unsub();
      sliderMusic?.removeEventListener("input", handleMusicSlider);
      sliderSfx?.removeEventListener("input", handleSfxSlider);
      btnResume?.removeEventListener("click", handleResume);
      btnPauseClose?.removeEventListener("click", handleResume);
      btnAbort?.removeEventListener("click", handleAbort);
      btnQuitYes?.removeEventListener("click", handleQuitYes);
      btnQuitCancel?.removeEventListener("click", handleQuitCancel);
    },
    {once: true}
  );
</script>
